---
import '../styles/global.css';
import Topbar from '../components/Topbar.astro';
import Header from '../components/Header.astro';
import LinksModule from '../components/LinksModule.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  ogImage?: string;
  ogImageAlt?: string;
  schema?: string;
  noindex?: boolean;
  breadcrumbSchema?: string;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogImage,
  ogImageAlt,
  schema,
  noindex = false,
  breadcrumbSchema,
} = Astro.props;

const siteURL = 'https://podiumex.com';
const canonicalURL = `${siteURL}${canonical}`;
const ogImageURL = ogImage
  ? (ogImage.startsWith('http') ? ogImage : `${siteURL}${ogImage}`)
  : `${siteURL}/img/img-general/coleccion-podiums-profesionales-variados.webp`;
const imageAlt = ogImageAlt || `${title} - PODIUMEX`;
---

<!DOCTYPE html>
<html lang="es-MX">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="telephone=no">

    <!-- SEO Primary -->
    <title>{title}</title>
    <meta name="description" content={description}>
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'}>
    <meta name="author" content="PODIUMEX">
    <meta name="language" content="es-MX">

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL}>

    <!-- Open Graph / Social -->
    <meta property="og:type" content={ogType}>
    <meta property="og:url" content={canonicalURL}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={ogImageURL}>
    <meta property="og:image:alt" content={imageAlt}>
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="es_MX">
    <meta property="og:site_name" content="PODIUMEX">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@podiumex">
    <meta name="twitter:title" content={title}>
    <meta name="twitter:description" content={description}>
    <meta name="twitter:image" content={ogImageURL}>
    <meta name="twitter:image:alt" content={imageAlt}>

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <link rel="icon" type="image/svg+xml" href="/icon.svg">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#0a1628">
    <meta name="msapplication-TileColor" content="#0a1628">

    <!-- Preconnect para performance -->
    <link rel="preconnect" href="https://wa.me">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">

    <!-- Schema JSON-LD principal -->
    {schema && <script type="application/ld+json" set:html={schema} />}
    <!-- Schema BreadcrumbList -->
    {breadcrumbSchema && <script type="application/ld+json" set:html={breadcrumbSchema} />}
</head>
<body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <Topbar />
    <Header />

    <main id="main-content" style="padding-top: var(--nav-offset, 104px);">
        <slot />
    </main>

    <LinksModule />
    <Footer />

    <button class="scroll-top" id="scrollTop" aria-label="Volver arriba" title="Volver arriba">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <div class="whatsapp-float" role="complementary" aria-label="Contacto WhatsApp">
        <span class="whatsapp-tooltip" aria-hidden="true">Cotiza por WhatsApp</span>
        <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20cotizar%20un%20podium%20para%20mi%20evento"
           class="whatsapp-float-btn"
           target="_blank"
           rel="noopener noreferrer"
           aria-label="Contactar PODIUMEX por WhatsApp">
            <span class="whatsapp-badge" aria-hidden="true">1</span>
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
        </a>
    </div>

    <script is:inline src="/js/app.js"></script>
</body>
</html>

<style is:global>
.skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    background: var(--primary, #0a1628);
    color: white;
    padding: 8px 16px;
    z-index: 10000;
    font-size: 0.875rem;
    border-radius: 0 0 4px 0;
    text-decoration: none;
    transition: top 0.2s;
}
.skip-link:focus {
    top: 0;
}
</style>
