---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },   // post.id = filename without extension in Astro v6
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);  // Astro v6: render(entry) not entry.render()
const { title, description, pubDate, updatedDate, author, category, image, imageAlt, tags } = post.data;

const formattedDate = pubDate.toLocaleDateString('es-MX', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const isoDate = pubDate.toISOString();
const isoUpdated = updatedDate?.toISOString() ?? isoDate;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": `https://podiumex.com${image}`,
  "datePublished": isoDate,
  "dateModified": isoUpdated,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": "https://podiumex.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "PODIUMEX",
    "logo": {
      "@type": "ImageObject",
      "url": "https://podiumex.com/img/podiumex.webp"
    },
    "url": "https://podiumex.com"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://podiumex.com/blog/${post.id}`
  },
  "keywords": tags.join(', '),
  "articleSection": category
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://podiumex.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://podiumex.com/blog" },
    { "@type": "ListItem", "position": 3, "name": title }
  ]
});
---

<Layout
  title={`${title} | PODIUMEX`}
  description={description}
  canonical={`/blog/${post.id}`}
  ogType="article"
  ogImage={image}
  ogImageAlt={imageAlt}
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Ruta de navegación" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <a href="/blog" class="breadcrumb-link">Blog</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <span class="breadcrumb-current" aria-current="page">{title}</span>
    </div>
  </nav>

  <!-- Artículo -->
  <article class="blog-article" itemscope itemtype="https://schema.org/Article">

    <header class="blog-article-header">
      <span class="card-tag">{category}</span>
      <h1 itemprop="headline">{title}</h1>
      <p class="blog-article-lead">{description}</p>

      <div class="blog-article-meta">
        <span itemprop="author" itemscope itemtype="https://schema.org/Organization">
          Por <strong itemprop="name">{author}</strong>
        </span>
        {/* Fechas en Schema.org invisibles para SEO */}
        <meta itemprop="datePublished" content={isoDate} />
        {updatedDate && <meta itemprop="dateModified" content={isoUpdated} />}
      </div>
    </header>

    <!-- Imagen destacada -->
    <img
      src={image}
      alt={imageAlt}
      width="800"
      height="450"
      class="blog-article-image"
      itemprop="image"
    />

    <!-- Contenido Markdown -->
    <div class="blog-article-content" itemprop="articleBody">
      <Content />
    </div>

    <!-- Tags -->
    <footer class="blog-article-footer">
      <p style="font-size:0.85rem;color:var(--text-medium);margin-bottom:0.5rem;">Temas:</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.5rem;">
        {tags.map((tag) => (
          <span style="background:var(--secondary);color:var(--primary);font-size:0.8rem;padding:0.25rem 0.75rem;border-radius:999px;font-weight:500;">
            #{tag}
          </span>
        ))}
      </div>
    </footer>

    <!-- CTA inline -->
    <div class="blog-cta-box">
      <h3>¿Necesitas un Podium para tu Evento?</h3>
      <p>Cotización personalizada en menos de 2 horas. Entrega express en CDMX, Monterrey y Guadalajara.</p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem;">
        <a href="https://wa.me/525564328954?text=Hola,%20lei%20el%20articulo%20del%20blog%20y%20quiero%20cotizar%20un%20podium"
           class="btn-whatsapp"
           target="_blank"
           rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar por WhatsApp
        </a>
        <a href="/catalogo" class="btn-primary">Ver Catálogo</a>
      </div>
    </div>

  </article>

</Layout>

<style>
.blog-article {
  max-width: 780px;
  margin: 0 auto;
  padding: 3rem 2rem 5rem;
}
.blog-article-header {
  margin-bottom: 2rem;
}
.blog-article-header h1 {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 700;
  color: var(--primary);
  line-height: 1.2;
  margin: 0.75rem 0 1rem;
}
.blog-article-lead {
  font-size: 1.05rem;
  color: var(--text-medium);
  line-height: 1.7;
  margin-bottom: 1rem;
}
.blog-article-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1rem;
  font-size: 0.875rem;
  color: var(--text-light);
}
.blog-article-image {
  width: 100%;
  height: auto;
  border-radius: var(--radius-lg);
  margin-bottom: 2.5rem;
  object-fit: cover;
  aspect-ratio: 16/9;
}
.blog-article-content {
  font-size: 1rem;
  color: var(--text-medium);
  line-height: 1.85;
}
.blog-article-content h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--primary);
  margin: 2.5rem 0 1rem;
}
.blog-article-content h3 {
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--primary);
  margin: 1.75rem 0 0.75rem;
}
.blog-article-content p {
  margin-bottom: 1.25rem;
}
.blog-article-content ul,
.blog-article-content ol {
  margin: 1rem 0 1.25rem 1.5rem;
}
.blog-article-content li {
  margin-bottom: 0.5rem;
}
.blog-article-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 1.5rem 0;
  font-size: 0.9rem;
}
.blog-article-content th {
  background: var(--primary);
  color: white;
  padding: 0.75rem 1rem;
  text-align: left;
  font-weight: 600;
}
.blog-article-content td {
  padding: 0.65rem 1rem;
  border-bottom: 1px solid var(--border);
}
.blog-article-content tr:nth-child(even) td {
  background: var(--secondary);
}
.blog-article-content strong {
  color: var(--primary);
  font-weight: 600;
}
.blog-article-footer {
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}
.blog-cta-box {
  background: var(--secondary);
  border-left: 4px solid var(--accent);
  border-radius: var(--radius-lg);
  padding: 2rem;
  margin-top: 3rem;
}
.blog-cta-box h3 {
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 0.5rem;
}
.blog-cta-box p {
  color: var(--text-medium);
  font-size: 0.95rem;
}
</style>
