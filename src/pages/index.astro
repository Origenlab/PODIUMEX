/* ── Hero ──────────────────────────────────────────── */
.ix-hero {
  padding: 3rem 5% 5rem;
  max-width: 1400px;
  margin: 0 auto;
}
.ix-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}
.ix-eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1.25rem;
}
.ix-eyebrow-dot {
  width: 8px;
  height: 8px;
  background: var(--accent);
  border-radius: 50%;
  display: inline-block;
}
.ix-hero-copy h1 {
  font-size: clamp(2.2rem, 5vw, 3.75rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--primary);
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
}
.ix-highlight {
  color: var(--accent);
}
.ix-hero-desc {
  font-size: 1.1rem;
  color: var(--text-medium);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 2rem;
}
.ix-hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.ix-hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
  padding-top: 2rem;
  border-top: 1px solid var(--border);
}
.ix-stat {
  text-align: center;
  flex: 1;
}
.ix-stat-num {
  display: block;
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--accent);
  line-height: 1.1;
}
.ix-stat-label {
  display: block;
  font-size: 0.78rem;
  color: var(--text-light);
  margin-top: 0.25rem;
}
.ix-stat-divider {
  width: 1px;
  height: 40px;
  background: var(--border);
}
/* ── Hero columna editorial (derecha) ──────────────── */
.ix-hero-editorial {
  padding: 2rem 0 2rem 3rem;
  border-left: 2px solid var(--border-light);
}
.ix-editorial-tag {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 0.875rem;
}
.ix-editorial-tag::before {
  content: '';
  display: inline-block;
  width: 28px;
  height: 2px;
  background: var(--accent);
  border-radius: 2px;
}
.ix-editorial-title {
  font-size: clamp(1.2rem, 2.2vw, 1.55rem);
  font-weight: 800;
  color: var(--primary);
  line-height: 1.25;
  letter-spacing: -0.02em;
  margin-bottom: 1.5rem;
}
.ix-editorial-p {
  font-size: 0.96rem;
  color: var(--text-medium);
  line-height: 1.85;
  margin-bottom: 1.25rem;
}
.ix-editorial-p strong {
  color: var(--primary);
  font-weight: 600;
}
.ix-editorial-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  margin-top: 1.75rem;
  padding-top: 1.75rem;
  border-top: 1px solid var(--border-light);
}
.ix-editorial-list li {
  display: flex;
  align-items: flex-start;
  gap: 0.625rem;
  font-size: 0.875rem;
  color: var(--text-medium);
  line-height: 1.55;
}
.ix-editorial-list li svg {
  flex-shrink: 0;
  margin-top: 2px;
  color: var(--accent);
}

/* ── Quick Links ───────────────────────────────────── */
.qlinks {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--white);
}
.qlink {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1.375rem 1.5rem;
  text-decoration: none;
  border-right: 1px solid var(--border);
  transition: background 0.15s;
  position: relative;
}
.qlink:last-child { border-right: none; }
.qlink:hover { background: #fafafa; }
.qlink-icon {
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  background: var(--secondary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
  transition: background 0.15s;
}
.qlink:hover .qlink-icon { background: rgba(184,134,11,0.10); }
.qlink-text {
  flex: 1;
  min-width: 0;
}
.qlink-text strong {
  display: block;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--primary);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.qlink-text span {
  display: block;
  font-size: 0.775rem;
  color: var(--text-light);
  margin-top: 0.15rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.qlink-arrow {
  flex-shrink: 0;
  color: var(--text-muted);
  transition: transform 0.15s, color 0.15s;
}
.qlink:hover .qlink-arrow {
  transform: translateX(3px);
  color: var(--accent);
}
/* Último ítem — CTA destacado */
.qlink--accent {
  background: var(--primary);
}
.qlink--accent:hover { background: #1a1a1a; }
.qlink--accent .qlink-icon {
  background: rgba(255,255,255,0.10);
  color: #25D366;
}
.qlink--accent:hover .qlink-icon { background: rgba(255,255,255,0.16); }
.qlink--accent .qlink-text strong { color: var(--white); }
.qlink--accent .qlink-text span { color: rgba(255,255,255,0.6); }
.qlink--accent .qlink-arrow { color: rgba(255,255,255,0.5); }
.qlink--accent:hover .qlink-arrow { color: var(--white); }

@media (max-width: 1024px) {
  .qlinks { grid-template-columns: repeat(3, 1fr); }
  .qlink:nth-child(3) { border-right: none; }
  .qlink:nth-child(4),
  .qlink:nth-child(5) { border-top: 1px solid var(--border); }
  .qlink:nth-child(5) { grid-column: span 1; border-right: none; }
}
@media (max-width: 640px) {
  .qlinks { grid-template-columns: 1fr 1fr; }
  .qlink { padding: 1rem 1rem; }
  .qlink:nth-child(odd) { border-right: 1px solid var(--border); }
  .qlink:nth-child(even) { border-right: none; }
  .qlink:nth-child(n+3) { border-top: 1px solid var(--border); }
  .qlink--accent { grid-column: span 2; border-right: none; }
  .qlink-text strong { font-size: 0.82rem; }
  .qlink-text span { display: none; }
}

/* ── Secciones generales ───────────────────────────── */
.ix-section {
  padding: 5rem 0;
}
.ix-section-alt {
  background: var(--secondary);
}
.ix-container {
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}
.ix-section-header {
  text-align: center;
  max-width: 680px;
  margin: 0 auto 3.5rem;
}
.ix-section-tag {
  display: inline-block;
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
