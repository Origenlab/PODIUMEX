---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "PODIUMEX",
  "description": "Venta y renta de podiums profesionales para eventos corporativos en Mexico",
  "telephone": "+52-55-3045-4714",
  "email": "podiumexmx@gmail.com",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Av. Tamaulipas 150-1301B",
    "addressLocality": "Col. Condesa, Ciudad de Mexico",
    "postalCode": "06140",
    "addressCountry": "MX"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "14:00"
    }
  ],
  "url": "https://podiumex.com",
  "image": "https://podiumex.com/img/podiumex.webp"
});
---

<Layout
  title="Venta de Podiums y Renta de Podium en Mexico | PODIUMEX - Podiums Profesionales"
  description="Venta de podiums y renta de podium en CDMX, Monterrey y Guadalajara. Podiums de acrilico, madera y LED. Entrega en 24hrs, personalizacion con logo. Cotiza tu venta de podium hoy."
  canonical="/"
  schema={schema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1><span class="highlight">Venta de Podiums</span> y <span class="highlight">Renta de Podium</span> en Mexico</h1>
        <p>Podiums profesionales de acrilico, madera y combinados para conferencias, ceremonias y eventos corporativos. Entrega en 24 horas en CDMX, Monterrey y Guadalajara con personalizacion de logo incluida.</p>
        <div class="hero-cta">
          <a href="https://wa.me/525530454714?text=Hola,%20me%20interesa%20cotizar%20un%20podium%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="/contacto" class="btn-primary">Cotizar Ahora</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">1,500+</span>
            <span class="stat-label">Eventos</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">24hrs</span>
            <span class="stat-label">Entrega</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">98.7%</span>
            <span class="stat-label">Satisfaccion</span>
          </div>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Podiums Profesionales para Eventos Corporativos de Alto Nivel</h2>
        <p>En PODIUMEX somos especialistas en la venta de podiums y renta de podium para eventos corporativos, conferencias de prensa, ceremonias gubernamentales y presentaciones ejecutivas en todo Mexico. Nuestros podiums de acrilico transparente, acrilico negro, madera y combinados estan disenados para proyectar la imagen profesional que tu evento requiere, con acabados premium y opciones de personalizacion con logo grabado o impreso.</p>
        <p>Ofrecemos cobertura en las principales ciudades de Mexico incluyendo CDMX, Monterrey, Guadalajara, Puebla y Queretaro, con entrega express en 24 horas y soporte tecnico especializado. Ya sea que necesites comprar un podium permanente para tu auditorio o rentar un podium para un evento especifico, en PODIUMEX encontraras la solucion ideal con la mejor relacion calidad-precio del mercado mexicano.</p>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="trust-content">
      <div class="trust-item">
        <div class="trust-text">
          <h3>Envio Nacional</h3>
          <p>A todo Mexico</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Entrega 24hrs</h3>
          <p>CDMX y area metropolitana</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Personalizacion</h3>
          <p>Logo grabado o impreso</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Pago Seguro</h3>
          <p>Transferencia y tarjeta</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Cards -->
  <section class="section-products">
    <div class="section-header">
      <h2>Nuestros Podiums Profesionales</h2>
      <p>Descubre nuestra linea completa de podiums de acrilico, madera y combinados para todo tipo de evento profesional.</p>
    </div>
    <div class="cards-grid">
      <a href="/catalogo/acrilico-transparente" class="product-card">
        <img src="/img/catalogo/acrilico-transparente.webp" alt="Podium de acrilico transparente profesional para conferencias y eventos corporativos" width="400" height="220" loading="lazy" />
        <div class="card-content">
          <span class="card-tag">Acrilico</span>
          <h3>Podium Acrilico Transparente</h3>
          <p>Podium de acrilico transparente con diseno moderno y elegante, ideal para conferencias de prensa, eventos corporativos y presentaciones ejecutivas.</p>
        </div>
      </a>
      <a href="/catalogo/acrilico-negro" class="product-card">
        <img src="/img/catalogo/acrilico-negro.webp" alt="Podium de acrilico negro elegante para presentaciones ejecutivas y galas" width="400" height="220" loading="lazy" />
        <div class="card-content">
          <span class="card-tag">Acrilico</span>
          <h3>Podium Acrilico Negro</h3>
          <p>Podium de acrilico negro con acabado premium, perfecto para galas, ceremonias de premiacion y presentaciones ejecutivas de alto impacto.</p>
        </div>
      </a>
      <a href="/catalogo/podium-madera-negro" class="product-card">
        <img src="/img/catalogo/podium-madera-negro.webp" alt="Podium de madera negra clasico para ceremonias oficiales y eventos gubernamentales" width="400" height="220" loading="lazy" />
        <div class="card-content">
          <span class="card-tag">Madera</span>
          <h3>Podium Madera Negro</h3>
          <p>Podium clasico de madera negra con acabado sobrio y profesional, ideal para ceremonias oficiales, eventos gubernamentales y actos academicos.</p>
        </div>
      </a>
      <a href="/catalogo/madera-caoba-acrilico" class="product-card">
        <img src="/img/catalogo/madera-caoba-acrilico.webp" alt="Podium combinado de madera caoba con acrilico para eventos premium" width="400" height="220" loading="lazy" />
        <div class="card-content">
          <span class="card-tag">Combinado</span>
          <h3>Podium Madera y Acrilico</h3>
          <p>Podium premium que combina la calidez de la madera caoba con la modernidad del acrilico, perfecto para eventos corporativos de alto nivel.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="section-services">
    <div class="section-header">
      <h2>Servicios Profesionales</h2>
      <p>Complementa tu podium con nuestros servicios especializados para garantizar el exito de tu evento.</p>
    </div>
    <div class="cards-grid">
      <a href="/entrega-e-instalacion" class="service-card">
        <div class="card-content">
          <span class="card-tag">Express</span>
          <h3>Entrega Express</h3>
          <p>Entrega e instalacion profesional en 24 horas en CDMX y area metropolitana. Envio a todo Mexico con tiempos garantizados y seguimiento en tiempo real.</p>
        </div>
      </a>
      <a href="/personalizacion-total" class="service-card">
        <div class="card-content">
          <span class="card-tag">Premium</span>
          <h3>Personalizacion</h3>
          <p>Personalizacion completa de tu podium con grabado laser de logo, rotulacion vinilica, iluminacion LED y acabados especiales segun tu imagen corporativa.</p>
        </div>
      </a>
      <a href="/setup-para-streaming" class="service-card">
        <div class="card-content">
          <span class="card-tag">Digital</span>
          <h3>Streaming</h3>
          <p>Configuracion profesional de audio, video y conectividad para transmision en vivo de conferencias y eventos hibridos desde tu podium.</p>
        </div>
      </a>
      <a href="/soporte-tecnico" class="service-card">
        <div class="card-content">
          <span class="card-tag">24/7</span>
          <h3>Soporte Tecnico</h3>
          <p>Equipo tecnico disponible para asistencia durante tu evento, mantenimiento preventivo y resolucion de cualquier incidencia en tiempo real.</p>
        </div>
      </a>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-content">
      <h2>Cotiza tu Podium Profesional</h2>
      <p>Contactanos para recibir una cotizacion personalizada. Venta y renta de podiums con entrega en todo Mexico.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525530454714?text=Hola,%20me%20interesa%20cotizar%20un%20podium%20para%20mi%20evento" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="/contacto" class="btn-call">Contactar</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-products, .section-services {
    padding: 4rem 0 0;
  }
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 1rem;
    padding: 0 2rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
  }
  .section-header p {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.7;
  }
</style>
