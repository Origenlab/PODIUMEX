---
import Layout from '../layouts/Layout.astro';

const title = "Personalizacion Total - Grabado Laser de Podiums | PODIUMEX Mexico";
const description = "Personaliza tu podium con grabado laser de alta precision. Logos corporativos, escudos institucionales y disenos a medida. PODIUMEX Mexico.";
---

<Layout title={title} description={description} canonical="/personalizacion-total">

  <div class="breadcrumbs" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <a href="/servicios" class="breadcrumb-link">Servicios</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <span class="breadcrumb-current">Personalizacion Total</span>
    </div>
  </div>

  <section class="hero" style="padding-top:2rem;">
    <div class="hero-content">
      <div class="hero-text">
        <h1><span class="highlight">Personalizacion</span> Total</h1>
        <p>Grabado laser de alta precision para que tu podium refleje la identidad de tu marca. Logos, escudos y disenos personalizados.</p>
        <div class="hero-stats">
          <div class="stat-item"><span class="stat-number">HD</span><span class="stat-label">Alta Resolucion</span></div>
          <div class="stat-item"><span class="stat-number">24hrs</span><span class="stat-label">Tiempo de Grabado</span></div>
          <div class="stat-item"><span class="stat-number">100%</span><span class="stat-label">Precision</span></div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20personalizar%20un%20podium" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar Personalizacion
          </a>
          <a href="tel:+525564328954" class="btn-call">Llamar Ahora</a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Grabado Laser Profesional para Podiums</h2>
        <p>La personalizacion con grabado laser es la forma mas elegante y profesional de incorporar la identidad de tu marca en un podium. Nuestra tecnologia CNC de alta precision permite reproducir logos corporativos, escudos gubernamentales e institucionales con un nivel de detalle excepcional.</p>
        <p>Cada grabado es permanente, resistente al uso y mantiene su calidad con el paso del tiempo. Trabajamos con archivos vectoriales para garantizar la maxima fidelidad al diseno original de tu marca.</p>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-content">
      <div class="trust-item"><div class="trust-text"><h3>Grabado Laser CNC</h3><p>Alta precision</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Permanente</h3><p>Resistente al uso</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Acrilico y Madera</h3><p>Todos los materiales</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>24hrs</h3><p>Tiempo de grabado</p></div></div>
    </div>
  </div>

  <section class="service-single-content">
    <div class="service-intro-section">
      <h2>Opciones de Personalizacion</h2>
      <p>Ofrecemos multiples opciones de personalizacion para adaptarnos a tus necesidades. Desde logos corporativos sencillos hasta disenos complejos con multiples elementos graficos.</p>
    </div>

    <div class="service-two-col">
      <div class="service-col">
        <h3>Tipos de Grabado</h3>
        <ul class="service-list">
          <li>Logos corporativos y marcas comerciales</li>
          <li>Escudos gubernamentales y oficiales</li>
          <li>Escudos universitarios e institucionales</li>
          <li>Disenos artisticos personalizados</li>
          <li>Texto y tipografia personalizada</li>
        </ul>
      </div>
      <div class="service-col">
        <h3>Materiales Compatibles</h3>
        <ul class="service-list">
          <li>Acrilico transparente - efecto iluminado</li>
          <li>Acrilico negro - contraste elegante</li>
          <li>Madera negro - grabado profesional</li>
          <li>Madera con acrilico - combinacion premium</li>
          <li>Placas metalicas opcionales</li>
        </ul>
      </div>
    </div>

    <div class="service-timeline">
      <h3>Proceso de Personalizacion</h3>
      <div class="timeline-steps">
        <div class="timeline-step"><div class="timeline-number">1</div><h4>Envio de Diseno</h4><p>Nos envias tu logo en formato vectorial (AI, SVG, EPS o PDF).</p></div>
        <div class="timeline-step"><div class="timeline-number">2</div><h4>Revision y Ajuste</h4><p>Nuestro equipo de diseno optimiza el archivo para grabado laser.</p></div>
        <div class="timeline-step"><div class="timeline-number">3</div><h4>Aprobacion</h4><p>Te enviamos una preview digital para tu aprobacion final.</p></div>
        <div class="timeline-step"><div class="timeline-number">4</div><h4>Grabado</h4><p>Realizamos el grabado laser con tecnologia CNC de alta precision.</p></div>
      </div>
    </div>

    <div class="service-banner">
      <h3>Resultado Premium Garantizado</h3>
      <p>Cada grabado pasa por un control de calidad visual antes de ser entregado. Garantizamos que el resultado final sera identico a la preview aprobada. Si no estas satisfecho, lo repetimos sin costo adicional.</p>
    </div>

    <!-- WhatsApp Form -->
    <div style="margin-top:3rem;">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Cotiza tu Personalizacion</h2>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
        <form id="whatsappForm" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Nombre *</label><input type="text" name="nombre" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu nombre"></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Empresa</label><input type="text" name="empresa" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu empresa"></div>
          <div style="grid-column:1/-1;"><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Descripcion del Grabado</label><textarea name="mensaje" rows="3" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;resize:vertical;" placeholder="Describe lo que deseas grabar..."></textarea></div>
          <div style="grid-column:1/-1;"><button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 2rem;background:#25D366;color:white;border:none;border-radius:var(--radius-md);font-weight:600;font-size:0.95rem;cursor:pointer;font-family:inherit;">Enviar por WhatsApp</button></div>
        </form>
      </div>
    </div>

    <div class="service-faq-section">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Preguntas sobre Personalizacion</h2>
      <div class="service-faq-item"><div class="service-faq-question"><span>En que formato debo enviar mi logo?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Preferimos archivos vectoriales: AI, SVG, EPS o PDF. Si solo tienes PNG o JPG en alta resolucion, podemos vectorizarlo con un cargo adicional.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Cuanto tiempo tarda el grabado?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>El grabado laser se realiza en 24 horas una vez aprobado el diseno. Para pedidos urgentes, consulta disponibilidad.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Se puede grabar en podiums de renta?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Para renta ofrecemos placas personalizadas removibles que se colocan en el podium durante tu evento. El grabado permanente esta disponible para venta.</p></div></div></div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2>Personaliza tu Podium Hoy</h2>
      <p>Dale identidad a tu podium con grabado laser profesional. Cotizacion rapida y sin compromiso.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20quiero%20personalizar%20un%20podium%20con%20mi%20logo" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
        <a href="/servicios" class="btn-call">Ver Servicios</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.service-faq-question').forEach(btn => { btn.addEventListener('click', () => { btn.parentElement?.classList.toggle('active'); }); });
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const d = (n: string) => (f.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value || '';
      let t = `Hola, me interesa personalizar un podium:\n\n*Nombre:* ${d('nombre')}`;
      if (d('empresa')) t += `\n*Empresa:* ${d('empresa')}`;
      if (d('mensaje')) t += `\n*Grabado:* ${d('mensaje')}`;
      window.open(`https://wa.me/525564328954?text=${encodeURIComponent(t)}`, '_blank');
    });
  </script>

</Layout>
