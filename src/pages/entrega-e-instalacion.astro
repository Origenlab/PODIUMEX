---
import Layout from '../layouts/Layout.astro';

const title = "Entrega e Instalacion Express de Podiums | PODIUMEX Mexico";
const description = "Servicio de entrega express en 24 horas e instalacion profesional de podiums en tu evento. CDMX, Monterrey, Guadalajara y todo Mexico.";
---

<Layout title={title} description={description} canonical="/entrega-e-instalacion">

  <!-- Breadcrumbs -->
  <div class="breadcrumbs" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <a href="/servicios" class="breadcrumb-link">Servicios</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <span class="breadcrumb-current">Entrega e Instalacion</span>
    </div>
  </div>

  <!-- Hero -->
  <section class="hero" style="padding-top:2rem;">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Entrega e <span class="highlight">Instalacion Express</span></h1>
        <p>Servicio de entrega en 24 horas e instalacion profesional en tu evento. Tu solo preocupate por tu presentacion, nosotros nos encargamos del resto.</p>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">24hrs</span>
            <span class="stat-label">CDMX/MTY/GDL</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">48-72hrs</span>
            <span class="stat-label">Todo Mexico</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Puntualidad</span>
          </div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20necesito%20servicio%20de%20entrega%20e%20instalacion" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Solicitar Entrega
          </a>
          <a href="tel:+525564328954" class="btn-call">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            Llamar Ahora
          </a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Logistica Profesional para tu Evento</h2>
        <p>Nuestro servicio de entrega e instalacion garantiza que tu podium llegue en perfectas condiciones y quede listo para usar. El equipo de PODIUMEX se encarga de la logistica completa: transporte seguro, montaje profesional, nivelacion precisa y configuracion de accesorios.</p>
        <p>Con cobertura en CDMX, Monterrey, Guadalajara y envios a todo Mexico, nuestro servicio express de 24 horas asegura que ningun evento se quede sin su podium. Contamos con vehiculos equipados y personal capacitado para manejar cada pieza con el maximo cuidado.</p>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="trust-content">
      <div class="trust-item"><div class="trust-text"><h3>24 Horas</h3><p>Entrega express</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Instalacion Incluida</h3><p>Montaje profesional</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Seguro de Traslado</h3><p>Proteccion total</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Recoleccion</h3><p>Al finalizar evento</p></div></div>
    </div>
  </div>

  <!-- Content -->
  <section class="service-single-content">
    <div class="service-intro-section">
      <h2>Como Funciona Nuestro Servicio de Entrega</h2>
      <p>El proceso de entrega e instalacion de PODIUMEX esta disenado para ser simple, eficiente y libre de preocupaciones. Desde el momento en que confirmas tu pedido, nuestro equipo de logistica se pone en accion para garantizar que todo este perfecto para tu evento.</p>
    </div>

    <div class="service-timeline">
      <h3>Proceso de Entrega</h3>
      <div class="timeline-steps">
        <div class="timeline-step">
          <div class="timeline-number">1</div>
          <h4>Confirmacion</h4>
          <p>Confirmas tu pedido y coordinamos la fecha, hora y lugar de entrega.</p>
        </div>
        <div class="timeline-step">
          <div class="timeline-number">2</div>
          <h4>Preparacion</h4>
          <p>Tu podium es inspeccionado, limpiado y embalado de forma segura.</p>
        </div>
        <div class="timeline-step">
          <div class="timeline-number">3</div>
          <h4>Entrega</h4>
          <p>Nuestro equipo llega puntualmente al venue con el podium.</p>
        </div>
        <div class="timeline-step">
          <div class="timeline-number">4</div>
          <h4>Instalacion</h4>
          <p>Montaje, nivelacion y configuracion en el escenario.</p>
        </div>
      </div>
    </div>

    <div class="service-two-col">
      <div class="service-col">
        <h3>Que Incluye la Entrega</h3>
        <ul class="service-list">
          <li>Transporte seguro en vehiculo equipado</li>
          <li>Seguro de traslado contra danos</li>
          <li>Entrega puntual en el venue</li>
          <li>Desembalaje y verificacion del estado</li>
          <li>Retiro de embalaje y materiales de proteccion</li>
        </ul>
      </div>
      <div class="service-col">
        <h3>Que Incluye la Instalacion</h3>
        <ul class="service-list">
          <li>Montaje profesional del podium</li>
          <li>Nivelacion precisa en el escenario</li>
          <li>Configuracion de microfonos (si aplica)</li>
          <li>Ajuste de posicion segun requerimientos</li>
          <li>Verificacion final con el cliente</li>
        </ul>
      </div>
    </div>

    <div class="info-cards-grid">
      <div class="info-card">
        <h4>CDMX y Area Metropolitana</h4>
        <p>Entrega en 24 horas. Instalacion y recoleccion incluidas en servicio de renta.</p>
      </div>
      <div class="info-card">
        <h4>Monterrey y Guadalajara</h4>
        <p>Entrega en 24-48 horas. Servicio de instalacion disponible con cargo adicional.</p>
      </div>
      <div class="info-card">
        <h4>Resto del Pais</h4>
        <p>Envios en 48-72 horas a cualquier ciudad. Embalaje reforzado para envios foraneos.</p>
      </div>
    </div>

    <div class="service-banner">
      <h3>Recoleccion Post-Evento</h3>
      <p>Para servicios de renta, nuestro equipo regresa al venue despues del evento para recoger el podium. Coordinamos la hora de recoleccion contigo para que no tengas que preocuparte por nada. El servicio de recoleccion esta incluido en la renta.</p>
    </div>

    <!-- WhatsApp Form -->
    <div style="margin-top:3rem;">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Solicita tu Entrega</h2>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
        <form id="whatsappForm" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div>
            <label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Nombre *</label>
            <input type="text" name="nombre" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu nombre">
          </div>
          <div>
            <label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Telefono *</label>
            <input type="tel" name="telefono" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="55 1234 5678">
          </div>
          <div>
            <label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Fecha del Evento</label>
            <input type="text" name="fecha" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Fecha aproximada">
          </div>
          <div>
            <label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Ubicacion</label>
            <input type="text" name="ubicacion" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Ciudad o venue">
          </div>
          <div style="grid-column:1/-1;">
            <label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Detalles</label>
            <textarea name="mensaje" rows="3" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;resize:vertical;" placeholder="Describe tu evento y necesidades..."></textarea>
          </div>
          <div style="grid-column:1/-1;">
            <button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 2rem;background:#25D366;color:white;border:none;border-radius:var(--radius-md);font-weight:600;font-size:0.95rem;cursor:pointer;font-family:inherit;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Enviar por WhatsApp
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- FAQ -->
    <div class="service-faq-section">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Preguntas Frecuentes sobre Entrega</h2>
      <div class="service-faq-item">
        <div class="service-faq-question"><span>Cual es el horario de entrega?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="service-faq-answer"><div class="service-faq-answer-content"><p>Realizamos entregas de lunes a sabado en horario de 8:00 a 20:00 hrs. Para eventos en domingo o dias festivos, coordinamos la entrega con anticipacion.</p></div></div>
      </div>
      <div class="service-faq-item">
        <div class="service-faq-question"><span>Que pasa si necesito la entrega de urgencia?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="service-faq-answer"><div class="service-faq-answer-content"><p>Contamos con servicio de entrega urgente para CDMX con disponibilidad el mismo dia. Contactanos por WhatsApp para verificar disponibilidad.</p></div></div>
      </div>
      <div class="service-faq-item">
        <div class="service-faq-question"><span>La instalacion tiene costo adicional?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div>
        <div class="service-faq-answer"><div class="service-faq-answer-content"><p>Para el servicio de renta en CDMX, la instalacion esta incluida. Para ventas y envios foraneos, consulta las opciones de instalacion disponibles.</p></div></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-content">
      <h2>Agenda tu Entrega Hoy</h2>
      <p>Garantizamos puntualidad y cuidado profesional en cada entrega. Cotiza sin compromiso.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20necesito%20servicio%20de%20entrega%20de%20podium" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar Entrega
        </a>
        <a href="/servicios" class="btn-call">Ver Servicios</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.service-faq-question').forEach(btn => {
      btn.addEventListener('click', () => { btn.parentElement?.classList.toggle('active'); });
    });
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const d = (n: string) => (f.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value || '';
      let t = `Hola, necesito servicio de entrega e instalacion:\n\n*Nombre:* ${d('nombre')}\n*Telefono:* ${d('telefono')}`;
      if (d('fecha')) t += `\n*Fecha:* ${d('fecha')}`;
      if (d('ubicacion')) t += `\n*Ubicacion:* ${d('ubicacion')}`;
      if (d('mensaje')) t += `\n*Detalles:* ${d('mensaje')}`;
      window.open(`https://wa.me/525564328954?text=${encodeURIComponent(t)}`, '_blank');
    });
  </script>

</Layout>
