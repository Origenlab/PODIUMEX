<style>
/* ═══════════════════════════════════════════════════════
   CATÁLOGO (L2) — ESTILOS ESPECÍFICOS
   Homologado al sistema ix-* del index
═══════════════════════════════════════════════════════ */

/* ── Breadcrumb ─────────────────────────────────────── */
.ct-breadcrumb {
  background: var(--secondary);
  border-bottom: 1px solid var(--border-light);
  padding: 0.75rem 0;
}
.ct-breadcrumb-list {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  list-style: none;
  font-size: 0.82rem;
  color: var(--text-light);
}
.ct-breadcrumb-list a {
  color: var(--text-medium);
  font-weight: 500;
}
.ct-breadcrumb-list a:hover { color: var(--accent); }
.ct-breadcrumb-list li[aria-current="page"] {
  color: var(--text-muted);
}
.ct-breadcrumb-list li svg {
  color: var(--border);
  flex-shrink: 0;
}

/* ── Hero ──────────────────────────────────────────── */
.ct-hero {
  padding: 3rem 5% 5rem;
  max-width: 1400px;
  margin: 0 auto;
}
.ct-hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: start;
}
.ct-hero-copy h1 {
  font-size: clamp(2.2rem, 5vw, 3.75rem);
  font-weight: 800;
  line-height: 1.1;
  color: var(--primary);
  letter-spacing: -0.03em;
  margin-bottom: 1.5rem;
}
.ct-hero-desc {
  font-size: 1.05rem;
  color: var(--text-medium);
  line-height: 1.75;
  max-width: 520px;
  margin-bottom: 2rem;
}
.ct-hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.ct-editorial-label {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--accent);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.ct-editorial-label::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 2px;
  background: var(--accent);
  border-radius: 2px;
}
.ct-hero-checks {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  margin-top: 1.75rem;
  padding-top: 1.75rem;
  border-top: 1px solid var(--border-light);
}
.ct-hero-checks li {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  font-size: 0.875rem;
  color: var(--text-medium);
  font-weight: 500;
}
.ct-hero-checks li svg {
  flex-shrink: 0;
  color: var(--accent);
}

/* ── Filtros de categoría ───────────────────────────── */
.ct-filters {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  background: var(--white);
}
.ct-filter {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1.25rem 1.375rem;
  text-decoration: none;
  border-right: 1px solid var(--border);
  color: var(--text-medium);
  font-size: 0.875rem;
  font-weight: 500;
  transition: background 0.15s, color 0.15s;
}
.ct-filter:last-child { border-right: none; }
.ct-filter:hover { background: #fafafa; color: var(--primary); }
.ct-filter--active {
  color: var(--primary);
  font-weight: 600;
  background: rgba(184, 134, 11, 0.04);
}
.ct-filter svg { flex-shrink: 0; color: var(--accent); }
.ct-filter span { flex: 1; }
.ct-filter strong {
  background: var(--secondary-dark);
  color: var(--text-light);
  font-size: 0.72rem;
  font-weight: 700;
  padding: 0.15rem 0.5rem;
  border-radius: 50px;
  flex-shrink: 0;
}
/* CTA destacado */
.ct-filter--cta {
  background: var(--primary);
  color: rgba(255,255,255,0.85);
}
.ct-filter--cta:hover { background: #1a1a1a; color: var(--white); }
.ct-filter--cta svg { color: #25D366; }

@media (max-width: 1100px) {
  .ct-filters { grid-template-columns: repeat(3, 1fr); }
  .ct-filter:nth-child(3) { border-right: none; }
  .ct-filter:nth-child(4),
  .ct-filter:nth-child(5) { border-top: 1px solid var(--border); }
  .ct-filter:nth-child(5) { border-right: none; }
}
@media (max-width: 640px) {
  .ct-filters { grid-template-columns: 1fr 1fr; }
  .ct-filter { padding: 0.875rem 1rem; font-size: 0.82rem; }
  .ct-filter:nth-child(odd) { border-right: 1px solid var(--border); }
  .ct-filter:nth-child(even) { border-right: none; }
  .ct-filter:nth-child(n+3) { border-top: 1px solid var(--border); }
  .ct-filter--cta { grid-column: span 2; border-right: none; }
}

/* ── Product card extras ────────────────────────────── */
.ct-card-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.375rem;
}
.ct-card-precio {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--accent);
}
/* Material badges por color */
.ct-mat-acrilico { background: rgba(59,130,246,0.08); color: #1e40af; }
.ct-mat-madera   { background: rgba(120,80,30,0.08); color: #78501e; }
.ct-mat-combinado { background: rgba(184,134,11,0.10); color: var(--accent-dark); }

.ct-card-usos {
  display: flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.78rem;
  color: var(--text-muted);
  margin-bottom: 1rem;
  font-style: italic;
}
.ct-card-usos svg { color: var(--accent); flex-shrink: 0; }

/* Badge especial compacto */
.ct-badge-compacto { background: var(--primary); }

/* ── Guía de Materiales ─────────────────────────────── */
.ct-materiales-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
.ct-material-card {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem 1.875rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  position: relative;
  transition: border-color 0.2s;
}
.ct-material-card:hover { border-color: var(--accent); }

/* Línea de acento por tipo */
.ct-material-card--acrilico  { border-top: 3px solid #3b82f6; }
.ct-material-card--madera    { border-top: 3px solid #78501e; }
.ct-material-card--combinado { border-top: 3px solid var(--accent); }

.ct-mat-header {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
}
.ct-mat-icon {
  flex-shrink: 0;
  width: 52px;
  height: 52px;
  background: var(--secondary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent);
}
.ct-mat-header h3 {
  font-size: 1.1rem;
  font-weight: 800;
  color: var(--primary);
