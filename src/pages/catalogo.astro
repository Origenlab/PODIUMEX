---
import Layout from '../layouts/Layout.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import SectionHeader from '../components/SectionHeader.astro';

// ─── Datos: Modelos Estándar ────────────────────────────────────────
const modelosEstandar = [
  {
    slug: 'acrilico-transparente',
    name: 'Acrílico Transparente',
    tag: 'Más Popular',
    material: 'Acrílico',
    materialColor: 'acrilico',
    image: '/img/catalogo/acrilico-transparente.webp',
    imageAlt: 'Podium de acrílico transparente profesional para conferencias corporativas y eventos de alto impacto en México',
    desc: 'Diseño minimalista y de alto impacto visual. El podium preferido por empresas líderes para conferencias, lanzamientos y eventos donde la imagen lo es todo.',
    specs: [
      { label: 'Altura', value: '120 cm' },
      { label: 'Ancho', value: '50 cm' },
      { label: 'Material', value: 'Acrílico 6 mm' },
      { label: 'Garantía', value: '2 años' },
    ],
    usos: 'Conferencias · Lanzamientos · Streaming',
    precio: 'Desde $8,500 MXN',
  },
  {
    slug: 'acrilico-negro',
    name: 'Acrílico Negro',
    tag: 'Elegancia Premium',
    material: 'Acrílico',
    materialColor: 'acrilico',
    image: '/img/catalogo/acrilico-negro.webp',
    imageAlt: 'Podium de acrílico negro para galas, ceremonias de premiación y eventos formales de lujo',
    desc: 'Sofisticación en cada detalle. Acabado oscuro de alto contraste ideal para galas, premiaciones y presentaciones ejecutivas donde el lujo es el mensaje.',
    specs: [
      { label: 'Altura', value: '120 cm' },
      { label: 'Ancho', value: '50 cm' },
      { label: 'Material', value: 'Acrílico 8 mm' },
      { label: 'Garantía', value: '2 años' },
    ],
    usos: 'Galas · Premiaciones · Eventos VIP',
    precio: 'Desde $9,200 MXN',
  },
  {
    slug: 'podium-madera-negro',
    name: 'Madera Negro',
    tag: 'Autoridad Clásica',
    material: 'Madera',
    materialColor: 'madera',
    image: '/img/catalogo/podium-madera-negro.webp',
    imageAlt: 'Podium de madera negra clásico para eventos gubernamentales, ceremonias académicas e instituciones formales',
    desc: 'Tradición, autoridad y solidez. La elección de gobiernos, universidades e instituciones que exigen formalidad absoluta en cada acto oficial.',
    specs: [
      { label: 'Altura', value: '120 cm' },
      { label: 'Ancho', value: '55 cm' },
      { label: 'Material', value: 'MDF lacado' },
      { label: 'Garantía', value: '3 años' },
    ],
    usos: 'Gobierno · Universidades · Ceremonias',
    precio: 'Desde $7,800 MXN',
  },
  {
    slug: 'madera-caoba-acrilico',
    name: 'Madera y Acrílico',
    tag: 'Diseño Híbrido',
    material: 'Combinado',
    materialColor: 'combinado',
    image: '/img/catalogo/madera-caoba-acrilico.webp',
    imageAlt: 'Podium combinado de madera caoba con acrílico para eventos corporativos premium en México',
    desc: 'Lo mejor de dos mundos. Cuerpo de madera caoba con fascia de acrílico: calidez, modernidad y personalización total en un solo modelo exclusivo.',
    specs: [
      { label: 'Altura', value: '120 cm' },
      { label: 'Ancho', value: '55 cm' },
      { label: 'Material', value: 'Madera + Acrílico' },
      { label: 'Garantía', value: '3 años' },
    ],
    usos: 'Corporativo · Hoteles · Eventos Exclusivos',
    precio: 'Desde $11,500 MXN',
  },
];

// ─── Datos: Modelos Compactos ───────────────────────────────────────
const modelosCompactos = [
  {
    slug: 'acrilico-transparente-compacto',
    name: 'Acrílico Transparente Compacto',
    tag: 'Compacto',
    material: 'Acrílico',
    materialColor: 'acrilico',
    image: '/img/catalogo/acrilico-transparente-compacto.webp',
    imageAlt: 'Podium compacto de acrílico transparente para estudios de grabación, podcasts y salas de juntas',
    desc: 'Toda la elegancia del modelo estándar en formato reducido. Ideal para estudios de grabación, salas de juntas ejecutivas y eventos donde el espacio es limitado.',
    specs: [
      { label: 'Altura', value: '95 cm' },
      { label: 'Ancho', value: '40 cm' },
      { label: 'Material', value: 'Acrílico 6 mm' },
      { label: 'Garantía', value: '2 años' },
    ],
    usos: 'Podcast · Studio · Salas de Juntas',
    precio: 'Desde $6,200 MXN',
  },
  {
    slug: 'acrilico-negro-compacto',
    name: 'Acrílico Negro Compacto',
    tag: 'Compacto',
    material: 'Acrílico',
    materialColor: 'acrilico',
    image: '/img/catalogo/acrilico-negro-compacto.webp',
    imageAlt: 'Podium compacto acrílico negro para presentaciones en espacios pequeños y eventos íntimos',
    desc: 'La presencia del acrílico negro en formato compacto. Perfecto para eventos íntimos, ceremonias de menor escala y presentaciones en espacios privados.',
    specs: [
      { label: 'Altura', value: '95 cm' },
      { label: 'Ancho', value: '40 cm' },
      { label: 'Material', value: 'Acrílico 8 mm' },
      { label: 'Garantía', value: '2 años' },
    ],
    usos: 'Eventos Íntimos · Oficinas · Galas Pequeñas',
    precio: 'Desde $6,900 MXN',
  },
  {
    slug: 'podium-madera-negro-compacto',
    name: 'Madera Negro Compacto',
    tag: 'Compacto',
    material: 'Madera',
    materialColor: 'madera',
    image: '/img/catalogo/podium-madera-negro-compacto.webp',
    imageAlt: 'Podium compacto de madera negra para salas de capacitación y ceremonias en espacios reducidos',
    desc: 'La solidez y autoridad del MDF lacado en versión compacta. La elección para capacitaciones corporativas, reuniones de directivos y ceremonias de formato íntimo.',
    specs: [
      { label: 'Altura', value: '95 cm' },
      { label: 'Ancho', value: '45 cm' },
      { label: 'Material', value: 'MDF lacado' },
      { label: 'Garantía', value: '3 años' },
    ],
    usos: 'Capacitación · Juntas Directivas · Salas VIP',
    precio: 'Desde $5,800 MXN',
  },
  {
    slug: 'madera-caoba-acrilico-compacto',
    name: 'Madera y Acrílico Compacto',
    tag: 'Compacto',
    material: 'Combinado',
    materialColor: 'combinado',
    image: '/img/catalogo/madera-caoba-acrilico-compacto.webp',
    imageAlt: 'Podium compacto combinado madera caoba y acrílico para eventos exclusivos en espacios reducidos',
    desc: 'La combinación de madera caoba y acrílico en formato compacto. Para eventos exclusivos donde el diseño premium debe adaptarse al espacio disponible.',
    specs: [
      { label: 'Altura', value: '95 cm' },
      { label: 'Ancho', value: '45 cm' },
      { label: 'Material', value: 'Madera + Acrílico' },
      { label: 'Garantía', value: '3 años' },
    ],
    usos: 'Eventos Exclusivos · Hoteles Boutique · Showrooms',
    precio: 'Desde $8,400 MXN',
  },
];

// ─── Datos: Guía de Materiales ──────────────────────────────────────
const materiales = [
  {
    id: 'acrilico',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    nombre: 'Acrílico',
    subtitulo: 'Modernidad y transparencia',
    desc: 'Material de vanguardia que proyecta innovación y apertura. La transparencia crea un escenario limpio donde el orador es el protagonista. Alta resistencia a impactos y manchas.',
    ideal: 'Empresas tecnológicas, startups, eventos de innovación, streaming, lanzamientos de producto.',
    ventajas: ['Efecto visual de gran impacto', 'Fácil de limpiar y mantener', 'Personalización con grabado láser', 'Disponible en transparente y negro'],
    modelos: ['Acrílico Transparente', 'Acrílico Negro'],
  },
  {
    id: 'madera',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    nombre: 'Madera',
    subtitulo: 'Autoridad y tradición',
    desc: 'MDF lacado de alta calidad que transmite solidez, formalidad y autoridad institucional. El lenguaje visual que gobiernos, universidades e instituciones han usado durante décadas.',
    ideal: 'Secretarías de gobierno, universidades, notarías, cámaras legislativas, ceremonias oficiales y graduaciones.',
    ventajas: ['Proyecta máxima autoridad institucional', 'Mayor resistencia estructural', 'Garantía de 3 años', 'Personalización con vinilado o grabado'],
    modelos: ['Madera Negro Estándar', 'Madera Negro Compacto'],
  },
  {
    id: 'combinado',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    nombre: 'Madera + Acrílico',
    subtitulo: 'Lo mejor de dos mundos',
    desc: 'La combinación premium que une la calidez de la madera caoba con la modernidad del acrílico. Diseño único que se adapta a cualquier ambientación y proyecta distinción.',
    ideal: 'Hoteles cinco estrellas, corporativos premium, agencias de marketing, eventos de lujo y showrooms exclusivos.',
    ventajas: ['Diseño exclusivo y diferenciador', 'Calidez + modernidad en un solo modelo', 'Personalización total en ambos materiales', 'El modelo más versátil del catálogo'],
    modelos: ['Madera y Acrílico Estándar', 'Madera y Acrílico Compacto'],
  },
];

// ─── Schema.org: ItemList del catálogo ─────────────────────────────
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Catálogo de Podiums Profesionales PODIUMEX",
  "description": "Catálogo completo de podiums profesionales para venta y renta en México: acrílico transparente, acrílico negro, madera y combinados en versión estándar y compacta.",
  "url": "https://podiumex.com/catalogo",
  "numberOfItems": 8,
  "itemListElement": [
    ...modelosEstandar.map((m, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://podiumex.com/catalogo/${m.slug}`,
      "name": `Podium ${m.name}`,
    })),
    ...modelosCompactos.map((m, i) => ({
      "@type": "ListItem",
      "position": modelosEstandar.length + i + 1,
      "url": `https://podiumex.com/catalogo/${m.slug}`,
      "name": `Podium ${m.name}`,
    })),
  ],
});

const breadcrumbSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://podiumex.com" },
    { "@type": "ListItem", "position": 2, "name": "Catálogo", "item": "https://podiumex.com/catalogo" },
  ],
});
---

<Layout
  title="Catálogo de Podiums Profesionales en México — 8 Modelos"
  description="Catálogo completo de podiums profesionales en México: acrílico transparente, acrílico negro, madera y combinados. Estándar y compacto. Venta con garantía y renta por evento. Fabricación nacional."
  canonical="/catalogo"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

<!-- ══════════════════════════════════════════════════
     BREADCRUMB
══════════════════════════════════════════════════ -->
<nav class="ct-breadcrumb" aria-label="Ruta de navegación">
  <div class="ix-container">
    <ol class="ct-breadcrumb-list">
      <li><a href="/">Inicio</a></li>
      <li aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </li>
      <li aria-current="page">Catálogo</li>
    </ol>
  </div>
</nav>

<!-- ══════════════════════════════════════════════════
     HERO
══════════════════════════════════════════════════ -->
<section class="ct-hero" aria-labelledby="ct-hero-title">
  <div class="ct-hero-inner">

    <!-- ── Columna izquierda: headline + CTA ── -->
    <div class="ct-hero-copy">

      <div class="ix-eyebrow">
        <span class="ix-eyebrow-dot" aria-hidden="true"></span>
        8 modelos · Estándar y Compacto · Fabricación Nacional
      </div>

      <h1 id="ct-hero-title">
        <span class="ix-highlight">Catálogo Completo</span><br>
        de Podiums<br>Profesionales
      </h1>

      <p class="ct-hero-desc">
        Cuatro materiales, dos tamaños, un estándar de calidad. Todos los modelos incluyen
        garantía escrita, personalización disponible y envío a todo México.
      </p>

      <div class="ct-hero-actions">
        <WhatsAppButton
          text="Cotizar Ahora"
          message="Hola, me interesa cotizar un podium del catálogo"
        />
        <a href="#modelos-estandar" class="btn-call">Ver Modelos →</a>
      </div>

      <!-- Stats -->
      <div class="ix-hero-stats">
        <div class="ix-stat">
          <span class="ix-stat-num">8</span>
          <span class="ix-stat-label">Modelos</span>
        </div>
        <div class="ix-stat-divider" aria-hidden="true"></div>
        <div class="ix-stat">
          <span class="ix-stat-num">3</span>
          <span class="ix-stat-label">Materiales</span>
        </div>
        <div class="ix-stat-divider" aria-hidden="true"></div>
        <div class="ix-stat">
          <span class="ix-stat-num">2</span>
          <span class="ix-stat-label">Tamaños</span>
        </div>
        <div class="ix-stat-divider" aria-hidden="true"></div>
        <div class="ix-stat">
          <span class="ix-stat-num">2–3</span>
          <span class="ix-stat-label">Años garantía</span>
        </div>
      </div>
    </div>

    <!-- ── Columna derecha: contenido editorial ── -->
    <div class="ix-hero-editorial">

      <p class="ct-editorial-label">¿Cuál es el modelo adecuado para tu evento?</p>

      <p class="ix-editorial-p">
        El catálogo PODIUMEX está diseñado para cubrir cada contexto de presentación:
        <strong>acrílico para eventos modernos e innovadores</strong>, madera para ceremonias
        institucionales de alto protocolo, y combinados para marcas que buscan distinción y exclusividad.
      </p>

      <p class="ix-editorial-p">
        Todos los modelos están disponibles para <strong>venta con financiamiento a meses sin
        intereses</strong> o para renta por evento con entrega, instalación y recolección incluidas.
        Personalización con grabado láser disponible en cualquier modelo.
      </p>

      <ul class="ct-hero-checks">
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Entrega e instalación express en 24 hrs (CDMX)
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Envío gratuito a toda la República Mexicana
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Grabado láser de logo sin costo adicional en compra
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
          Asesoría gratuita para elegir el modelo correcto
        </li>
      </ul>

    </div>
  </div>
</section>

<!-- ══════════════════════════════════════════════════
     QUICK LINKS — FILTRO DE CATEGORÍAS
══════════════════════════════════════════════════ -->
<nav class="ct-filters" aria-label="Filtrar por tipo de podium">
  <a href="#modelos-estandar" class="ct-filter ct-filter--active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="7" height="7"/><rect x="15" y="3" width="7" height="7"/><rect x="15" y="14" width="7" height="7"/><rect x="2" y="14" width="7" height="7"/></svg>
    <span>Todos los Modelos</span>
    <strong>8</strong>
  </a>
  <a href="#modelos-estandar" class="ct-filter">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
    <span>Modelos Estándar</span>
    <strong>4</strong>
  </a>
  <a href="#modelos-compactos" class="ct-filter">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
    <span>Modelos Compactos</span>
    <strong>4</strong>
  </a>
  <a href="#guia-materiales" class="ct-filter">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
    <span>Guía de Materiales</span>
  </a>
  <a href="https://wa.me/525516567973?text=Hola%2C%20quiero%20asesor%C3%ADa%20para%20elegir%20el%20podium%20correcto" target="_blank" rel="noopener noreferrer" class="ct-filter ct-filter--cta">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
    <span>Asesoría Gratuita</span>
  </a>
</nav>

<!-- ══════════════════════════════════════════════════
     MODELOS ESTÁNDAR
══════════════════════════════════════════════════ -->
<section class="ix-section" id="modelos-estandar" aria-labelledby="estandar-title">
  <div class="ix-container">

    <SectionHeader
      tag="Modelos Estándar"
      title="Podiums de Tamaño Completo — 120 cm"
      description="Cuatro modelos diseñados para auditorios, salones de eventos y espacios corporativos donde la presencia visual es parte del protocolo."
      id="estandar-title"
      p1="Los modelos estándar están diseñados para <strong>auditorios, salones de eventos, salas de prensa y escenarios formales</strong> donde la presencia del podium comunica autoridad y profesionalismo desde el primer momento."
      p2="Cada modelo incluye <strong>garantía escrita de 2 a 3 años, envío gratuito nacional y personalización con grabado láser</strong> disponible. Disponibles para compra con financiamiento o renta por evento."
    />

    <div class="ix-products-grid">
      {modelosEstandar.map((p) => (
        <article class={`ix-product-card ct-product-card`}>
          <a href={`/catalogo/${p.slug}`} class="ix-product-img-link" tabindex="-1" aria-hidden="true">
            <img src={p.image} alt={p.imageAlt} width="480" height="300" loading="lazy" />
            <span class="ix-product-badge">{p.tag}</span>
          </a>
          <div class="ix-product-body">
            <div class="ct-card-meta">
              <span class={`card-tag ct-mat-${p.materialColor}`}>{p.material}</span>
              <span class="ct-card-precio">{p.precio}</span>
            </div>
            <h3>
              <a href={`/catalogo/${p.slug}`}>Podium {p.name}</a>
            </h3>
            <p>{p.desc}</p>

            <ul class="ix-product-specs" aria-label={`Especificaciones del podium ${p.name}`}>
              {p.specs.map(s => (
                <li>
                  <span class="spec-label">{s.label}</span>
                  <span class="spec-value">{s.value}</span>
                </li>
              ))}
            </ul>

            <div class="ct-card-usos">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              {p.usos}
            </div>

            <div class="ix-product-actions">
              <WhatsAppButton
                text="Cotizar"
                message={`Hola, me interesa cotizar el podium ${p.name}`}
              />
              <a href={`/catalogo/${p.slug}`} class="ix-link-more">Ver detalles →</a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<!-- ══════════════════════════════════════════════════
