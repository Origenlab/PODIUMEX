---
import Layout from '../layouts/Layout.astro';

const title = "Financiamiento Flexible para Podiums | PODIUMEX Mexico";
const description = "Opciones de financiamiento y pago flexible para compra de podiums profesionales. Meses sin intereses, transferencia, facturacion para empresas y gobierno.";
---

<Layout title={title} description={description} canonical="/financiamiento">

  <div class="breadcrumbs" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <a href="/servicios" class="breadcrumb-link">Servicios</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <span class="breadcrumb-current">Financiamiento</span>
    </div>
  </div>

  <section class="hero" style="padding-top:2rem;">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Financiamiento <span class="highlight">Flexible</span></h1>
        <p>Multiples opciones de pago para que adquieras tu podium profesional sin comprometer tu presupuesto.</p>
        <div class="hero-stats">
          <div class="stat-item"><span class="stat-number">MSI</span><span class="stat-label">Meses sin Intereses</span></div>
          <div class="stat-item"><span class="stat-number">100%</span><span class="stat-label">Facturable</span></div>
          <div class="stat-item"><span class="stat-number">3+</span><span class="stat-label">Metodos de Pago</span></div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20quiero%20conocer%20las%20opciones%20de%20financiamiento" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Consultar Opciones
          </a>
          <a href="tel:+525564328954" class="btn-call">Llamar Ahora</a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Opciones de Pago para Cada Necesidad</h2>
        <p>En PODIUMEX entendemos que la inversion en equipamiento profesional debe ser accesible. Por eso ofrecemos multiples esquemas de financiamiento y pago que se adaptan a las necesidades de empresas, instituciones y particulares.</p>
        <p>Desde meses sin intereses con tarjeta de credito hasta esquemas de facturacion para gobierno y corporativos, tenemos la opcion perfecta para ti. Todos nuestros productos son 100% facturables.</p>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-content">
      <div class="trust-item"><div class="trust-text"><h3>Meses sin Intereses</h3><p>Tarjeta de credito</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Transferencia</h3><p>Bancaria</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Facturacion</h3><p>CFDI</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Pago Corporativo</h3><p>Orden de compra</p></div></div>
    </div>
  </div>

  <section class="service-single-content">
    <div class="service-intro-section">
      <h2>Metodos de Pago Disponibles</h2>
      <p>Ofrecemos flexibilidad total para que el metodo de pago no sea un obstaculo. Elige la opcion que mejor se adapte a tus procesos administrativos.</p>
    </div>

    <div class="info-cards-grid">
      <div class="info-card"><h4>Tarjeta de Credito</h4><p>Pago con tarjeta de credito Visa, MasterCard y American Express. Disponible en meses sin intereses segun promociones vigentes.</p></div>
      <div class="info-card"><h4>Transferencia Bancaria</h4><p>Pago por transferencia SPEI. Confirmacion inmediata y comprobante digital. Ideal para montos empresariales.</p></div>
      <div class="info-card"><h4>Facturacion CFDI</h4><p>Emitimos factura fiscal CFDI para todas las compras. Ideal para empresas y dependencias de gobierno que requieren comprobante fiscal.</p></div>
    </div>

    <div class="service-two-col">
      <div class="service-col">
        <h3>Para Empresas</h3>
        <ul class="service-list">
          <li>Facturacion empresarial CFDI</li>
          <li>Ordenes de compra aceptadas</li>
          <li>Credito empresarial (sujeto a aprobacion)</li>
          <li>Descuentos por volumen</li>
          <li>Planes de adquisicion por etapas</li>
        </ul>
      </div>
      <div class="service-col">
        <h3>Para Gobierno</h3>
        <ul class="service-list">
          <li>Facturacion para dependencias gubernamentales</li>
          <li>Proceso de licitacion y cotizacion formal</li>
          <li>Cumplimiento de requisitos administrativos</li>
          <li>Entrega con documentacion completa</li>
          <li>Contratos de servicio anuales</li>
        </ul>
      </div>
    </div>

    <div class="service-banner">
      <h3>Renta como Alternativa Economica</h3>
      <p>Si tu presupuesto es limitado o solo necesitas un podium para un evento especifico, la renta es una excelente alternativa. Obtienes la misma calidad premium sin la inversion completa, con entrega, instalacion y recoleccion incluidas.</p>
    </div>

    <div style="margin-top:3rem;">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Consulta Opciones de Pago</h2>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
        <form id="whatsappForm" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Nombre *</label><input type="text" name="nombre" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu nombre"></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Empresa</label><input type="text" name="empresa" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu empresa"></div>
          <div style="grid-column:1/-1;"><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Que producto te interesa?</label><textarea name="mensaje" rows="3" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;resize:vertical;" placeholder="Describe el producto y metodo de pago que prefieres..."></textarea></div>
          <div style="grid-column:1/-1;"><button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 2rem;background:#25D366;color:white;border:none;border-radius:var(--radius-md);font-weight:600;font-size:0.95rem;cursor:pointer;font-family:inherit;">Enviar por WhatsApp</button></div>
        </form>
      </div>
    </div>

    <div class="service-faq-section">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Preguntas sobre Financiamiento</h2>
      <div class="service-faq-item"><div class="service-faq-question"><span>A cuantos meses sin intereses puedo pagar?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Las opciones de meses sin intereses varian segun las promociones vigentes y el banco emisor de tu tarjeta. Contactanos para conocer las promociones actuales.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Emiten factura fiscal?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Si, emitimos factura CFDI para todas las compras y servicios de renta. Solo necesitamos tus datos fiscales al momento de la compra.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Aceptan ordenes de compra?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Si, aceptamos ordenes de compra de empresas y dependencias de gobierno. El proceso incluye cotizacion formal, revision y aprobacion.</p></div></div></div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2>Encuentra la Opcion de Pago Ideal</h2>
      <p>Consultanos sobre las opciones de financiamiento disponibles para tu compra. Sin compromiso.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20quiero%20conocer%20opciones%20de%20financiamiento" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">Consultar por WhatsApp</a>
        <a href="/servicios" class="btn-call">Ver Servicios</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.service-faq-question').forEach(btn => { btn.addEventListener('click', () => { btn.parentElement?.classList.toggle('active'); }); });
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const d = (n: string) => (f.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value || '';
      let t = `Hola, quiero informacion sobre financiamiento:\n\n*Nombre:* ${d('nombre')}`;
      if (d('empresa')) t += `\n*Empresa:* ${d('empresa')}`;
      if (d('mensaje')) t += `\n*Interes:* ${d('mensaje')}`;
      window.open(`https://wa.me/525564328954?text=${encodeURIComponent(t)}`, '_blank');
    });
  </script>

</Layout>
