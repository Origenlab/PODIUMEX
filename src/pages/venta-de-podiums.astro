---
import Layout from '../layouts/Layout.astro';
import { itemListSchema, breadcrumb } from '../data/schema';

const ventaItems = [
  { name: 'Podium Acrílico Transparente', path: '/catalogo/acrilico-transparente' },
  { name: 'Podium Acrílico Negro', path: '/catalogo/acrilico-negro' },
  { name: 'Podium Madera Negro', path: '/catalogo/podium-madera-negro' },
  { name: 'Podium Madera Caoba con Acrílico', path: '/catalogo/madera-caoba-acrilico' },
  { name: 'Podium Acrílico Transparente Compacto', path: '/catalogo/acrilico-transparente-compacto' },
  { name: 'Podium Acrílico Negro Compacto', path: '/catalogo/acrilico-negro-compacto' },
  { name: 'Podium Madera Negro Compacto', path: '/catalogo/podium-madera-negro-compacto' },
  { name: 'Podium Madera Caoba con Acrílico Compacto', path: '/catalogo/madera-caoba-acrilico-compacto' },
];
const schema = itemListSchema(
  'Venta de Podiums Profesionales en México',
  'Catálogo de podiums profesionales disponibles para compra en México: acrílico, madera y combinados, en versión estándar y compacta.',
  '/venta-de-podiums',
  ventaItems
);
const breadcrumbSchema = breadcrumb([
  { name: 'Inicio', path: '/' },
  { name: 'Venta de Podiums' },
]);
---

<Layout
  title="Venta de Podiums Profesionales en Mexico | Comprar Podium"
  description="Venta de podiums profesionales en México: acrílico, madera y combinados para conferencias, eventos corporativos y ceremonias. Envío a todo el país."
  canonical="/venta-de-podiums"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1><span class="highlight">Venta de Podiums</span> Profesionales en México</h1>
        <p>Compra tu podium profesional con envío a todo México. Modelos en acrílico, madera y combinados con garantía, personalización y opciones de financiamiento.</p>
        <div class="hero-cta">
          <a href="https://wa.me/525516567973?text=Hola,%20me%20interesa%20comprar%20un%20podium%20profesional" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Comprar por WhatsApp
          </a>
          <a href="/contacto" class="btn-primary">Cotizar Ahora</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">8</span>
            <span class="stat-label">Modelos</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">24hrs</span>
            <span class="stat-label">Entrega CDMX</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Garantía</span>
          </div>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Compra tu Podium Profesional con Envío a Todo México</h2>
        <p>La venta de podiums profesionales de PODIUMEX te ofrece la mejor selección de podiums de acrílico, madera y combinados del mercado mexicano. Cada podium es fabricado con materiales de primera calidad, diseno ergonomico y acabados que proyectan la imagen corporativa que tu empresa necesita en conferencias, ceremonias y presentaciones ejecutivas.</p>
        <p>Al comprar tu podium con nosotros obtienes envío a todo México, garantía de fabrica, opciones de personalización con logo y la posibilidad de financiamiento en pagos. Nuestros podiums estan disponibles en tamaño estándar y compacto para adaptarse a cualquier espacio y tipo de evento profesional.</p>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="trust-content">
      <div class="trust-item">
        <div class="trust-text">
          <h3>Envío Nacional</h3>
          <p>A todo México</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Entrega 24hrs</h3>
          <p>CDMX y area metropolitana</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Personalización</h3>
          <p>Logo grabado o impreso</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Pago Seguro</h3>
          <p>Transferencia y tarjeta</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Modelos Estandar -->
  <section class="section-catalog">
    <div class="section-header">
      <h2>Modelos Estándar</h2>
      <p>Podiums de tamaño completo disponibles para compra inmediata.</p>
    </div>
    <div class="cards-grid">
      <div class="product-card">
        <a href="/catalogo/acrilico-transparente">
          <img src="/img/catalogo/acrilico-transparente.webp" alt="Comprar podium de acrilico transparente profesional para conferencias y eventos corporativos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrílico</span>
          <h3>Podium Acrílico Transparente</h3>
          <p>Podium de acrílico transparente de alta resistencia con diseno moderno para conferencias de prensa y eventos corporativos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-transparente" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/acrilico-negro">
          <img src="/img/catalogo/acrilico-negro.webp" alt="Comprar podium de acrilico negro elegante para presentaciones ejecutivas y galas corporativas" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrílico</span>
          <h3>Podium Acrílico Negro</h3>
          <p>Podium de acrílico negro con acabado premium, perfecto para galas, premiaciones y presentaciones ejecutivas de alto impacto.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-negro" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/podium-madera-negro">
          <img src="/img/catalogo/podium-madera-negro.webp" alt="Comprar podium de madera negra clasico para ceremonias oficiales y eventos gubernamentales" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Madera</span>
          <h3>Podium Madera Negro</h3>
          <p>Podium clasico de madera negra con acabado sobrio y profesional para ceremonias oficiales y eventos gubernamentales.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/podium-madera-negro" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/madera-caoba-acrilico">
          <img src="/img/catalogo/madera-caoba-acrilico.webp" alt="Comprar podium combinado de madera caoba con acrilico para eventos premium y corporativos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Combinado</span>
          <h3>Podium Madera y Acrílico</h3>
          <p>Podium premium de madera caoba con panel de acrílico, fusión de elegancia clasica y modernidad para eventos de primer nivel.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/madera-caoba-acrilico" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modelos Compactos -->
  <section class="section-catalog">
    <div class="section-header">
      <h2>Modelos Compactos</h2>
      <p>Podiums de tamaño reducido ideales para oficinas, estudios y espacios pequenos.</p>
    </div>
    <div class="cards-grid">
      <div class="product-card">
        <a href="/catalogo/acrilico-transparente-compacto">
          <img src="/img/catalogo/acrilico-transparente-compacto.webp" alt="Comprar podium compacto de acrilico transparente para estudios de grabacion y salas de juntas" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrílico Compacto</span>
          <h3>Podium Acrílico Transparente Compacto</h3>
          <p>Versión compacta en acrílico transparente para estudios de grabación, salas de juntas y espacios reducidos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-transparente-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/acrilico-negro-compacto">
          <img src="/img/catalogo/acrilico-negro-compacto.webp" alt="Comprar podium compacto de acrilico negro para presentaciones en espacios pequenos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrílico Compacto</span>
          <h3>Podium Acrílico Negro Compacto</h3>
          <p>Podium compacto en acrílico negro con acabado premium, optimizado para presentaciones en espacios reducidos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-negro-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/podium-madera-negro-compacto">
          <img src="/img/catalogo/podium-madera-negro-compacto.webp" alt="Comprar podium compacto de madera negra para oficinas corporativas y salas de capacitacion" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Madera Compacto</span>
          <h3>Podium Madera Negro Compacto</h3>
          <p>Versión compacta del podium de madera negra, perfecto para oficinas corporativas y salas de capacitación.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/podium-madera-negro-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/madera-caoba-acrilico-compacto">
          <img src="/img/catalogo/madera-caoba-acrilico-compacto.webp" alt="Comprar podium compacto combinado de madera caoba con acrilico para eventos exclusivos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Combinado Compacto</span>
          <h3>Podium Madera y Acrílico Compacto</h3>
          <p>Combinación premium de madera caoba y acrílico en formato compacto para espacios pequenos y eventos selectos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/madera-caoba-acrilico-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="benefits-section">
    <div class="section-header">
      <h2>Beneficios de Comprar tu Podium en PODIUMEX</h2>
      <p>Cada compra incluye ventajas exclusivas para garantizar tu satisfacción.</p>
    </div>
    <div class="cards-grid">
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Logística</span>
          <h3>Envío Nacional</h3>
          <p>Envío seguro y asegurado a cualquier ciudad de México. Entrega express en 24 horas para CDMX y area metropolitana con seguimiento en tiempo real de tu pedido.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Calidad</span>
          <h3>Garantía de Fabrica</h3>
          <p>Todos nuestros podiums incluyen garantía de fabrica que cubre defectos de manufactura y materiales. Respaldo total en la calidad de tu inversión.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Branding</span>
          <h3>Personalización con Logo</h3>
          <p>Personaliza tu podium con grabado láser o rotulación vinilica de tu logo corporativo. Opciones de iluminación LED y acabados especiales disponibles.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Pagos</span>
          <h3>Financiamiento Flexible</h3>
          <p>Opciones de pago a meses sin intereses con tarjeta de credito. Tambien aceptamos transferencia bancaria, deposito y pagos corporativos con factura.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-content">
      <h2>Compra tu Podium Profesional</h2>
      <p>Recibe una cotización personalizada con las mejores condiciones del mercado. Envío a todo México.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525516567973?text=Hola,%20me%20interesa%20comprar%20un%20podium%20profesional" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Comprar por WhatsApp
        </a>
        <a href="/contacto" class="btn-call">Contactar</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-catalog, .benefits-section {
    padding: 4rem 0 0;
  }
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 1rem;
    padding: 0 2rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
  }
  .section-header p {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.7;
  }
  .card-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .card-actions .btn-primary,
  .card-actions .btn-call {
    padding: 0.625rem 1.25rem;
    font-size: 0.85rem;
  }
</style>
