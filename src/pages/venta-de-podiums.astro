---
import Layout from '../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Venta de Podiums Profesionales en Mexico",
  "description": "Catalogo de podiums profesionales disponibles para compra en Mexico",
  "url": "https://podiumex.com/venta-de-podiums",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Podium Acrilico Transparente",
        "url": "https://podiumex.com/catalogo/acrilico-transparente"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Podium Acrilico Negro",
        "url": "https://podiumex.com/catalogo/acrilico-negro"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": "Podium Madera Negro",
        "url": "https://podiumex.com/catalogo/podium-madera-negro"
      },
      {
        "@type": "ListItem",
        "position": 4,
        "name": "Podium Madera y Acrilico",
        "url": "https://podiumex.com/catalogo/madera-caoba-acrilico"
      },
      {
        "@type": "ListItem",
        "position": 5,
        "name": "Podium Acrilico Transparente Compacto",
        "url": "https://podiumex.com/catalogo/acrilico-transparente-compacto"
      },
      {
        "@type": "ListItem",
        "position": 6,
        "name": "Podium Acrilico Negro Compacto",
        "url": "https://podiumex.com/catalogo/acrilico-negro-compacto"
      },
      {
        "@type": "ListItem",
        "position": 7,
        "name": "Podium Madera Negro Compacto",
        "url": "https://podiumex.com/catalogo/podium-madera-negro-compacto"
      },
      {
        "@type": "ListItem",
        "position": 8,
        "name": "Podium Madera y Acrilico Compacto",
        "url": "https://podiumex.com/catalogo/madera-caoba-acrilico-compacto"
      }
    ]
  }
});
---

<Layout
  title="Venta de Podiums Profesionales en Mexico | Comprar Podium PODIUMEX"
  description="Venta de podiums profesionales en Mexico. Compra podium de acrilico, madera y combinados para eventos corporativos, conferencias y ceremonias. Envio a todo Mexico."
  canonical="/venta-de-podiums"
  schema={schema}
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1><span class="highlight">Venta de Podiums</span> Profesionales en Mexico</h1>
        <p>Compra tu podium profesional con envio a todo Mexico. Modelos en acrilico, madera y combinados con garantia, personalizacion y opciones de financiamiento.</p>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20comprar%20un%20podium%20profesional" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Comprar por WhatsApp
          </a>
          <a href="/contacto" class="btn-primary">Cotizar Ahora</a>
        </div>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">8</span>
            <span class="stat-label">Modelos</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">24hrs</span>
            <span class="stat-label">Entrega CDMX</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">100%</span>
            <span class="stat-label">Garantia</span>
          </div>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Compra tu Podium Profesional con Envio a Todo Mexico</h2>
        <p>La venta de podiums profesionales de PODIUMEX te ofrece la mejor seleccion de podiums de acrilico, madera y combinados del mercado mexicano. Cada podium es fabricado con materiales de primera calidad, diseno ergonomico y acabados que proyectan la imagen corporativa que tu empresa necesita en conferencias, ceremonias y presentaciones ejecutivas.</p>
        <p>Al comprar tu podium con nosotros obtienes envio a todo Mexico, garantia de fabrica, opciones de personalizacion con logo y la posibilidad de financiamiento en pagos. Nuestros podiums estan disponibles en tamano estandar y compacto para adaptarse a cualquier espacio y tipo de evento profesional.</p>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="trust-bar">
    <div class="trust-content">
      <div class="trust-item">
        <div class="trust-text">
          <h3>Envio Nacional</h3>
          <p>A todo Mexico</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Entrega 24hrs</h3>
          <p>CDMX y area metropolitana</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Personalizacion</h3>
          <p>Logo grabado o impreso</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Pago Seguro</h3>
          <p>Transferencia y tarjeta</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Modelos Estandar -->
  <section class="section-catalog">
    <div class="section-header">
      <h2>Modelos Estandar</h2>
      <p>Podiums de tamano completo disponibles para compra inmediata.</p>
    </div>
    <div class="cards-grid">
      <div class="product-card">
        <a href="/catalogo/acrilico-transparente">
          <img src="/img/catalogo/acrilico-transparente.webp" alt="Comprar podium de acrilico transparente profesional para conferencias y eventos corporativos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrilico</span>
          <h3>Podium Acrilico Transparente</h3>
          <p>Podium de acrilico transparente de alta resistencia con diseno moderno para conferencias de prensa y eventos corporativos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-transparente" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/acrilico-negro">
          <img src="/img/catalogo/acrilico-negro.webp" alt="Comprar podium de acrilico negro elegante para presentaciones ejecutivas y galas corporativas" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrilico</span>
          <h3>Podium Acrilico Negro</h3>
          <p>Podium de acrilico negro con acabado premium, perfecto para galas, premiaciones y presentaciones ejecutivas de alto impacto.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-negro" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/podium-madera-negro">
          <img src="/img/catalogo/podium-madera-negro.webp" alt="Comprar podium de madera negra clasico para ceremonias oficiales y eventos gubernamentales" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Madera</span>
          <h3>Podium Madera Negro</h3>
          <p>Podium clasico de madera negra con acabado sobrio y profesional para ceremonias oficiales y eventos gubernamentales.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/podium-madera-negro" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/madera-caoba-acrilico">
          <img src="/img/catalogo/madera-caoba-acrilico.webp" alt="Comprar podium combinado de madera caoba con acrilico para eventos premium y corporativos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Combinado</span>
          <h3>Podium Madera y Acrilico</h3>
          <p>Podium premium de madera caoba con panel de acrilico, fusion de elegancia clasica y modernidad para eventos de primer nivel.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/madera-caoba-acrilico" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modelos Compactos -->
  <section class="section-catalog">
    <div class="section-header">
      <h2>Modelos Compactos</h2>
      <p>Podiums de tamano reducido ideales para oficinas, estudios y espacios pequenos.</p>
    </div>
    <div class="cards-grid">
      <div class="product-card">
        <a href="/catalogo/acrilico-transparente-compacto">
          <img src="/img/catalogo/acrilico-transparente-compacto.webp" alt="Comprar podium compacto de acrilico transparente para estudios de grabacion y salas de juntas" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrilico Compacto</span>
          <h3>Podium Acrilico Transparente Compacto</h3>
          <p>Version compacta en acrilico transparente para estudios de grabacion, salas de juntas y espacios reducidos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-transparente-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/acrilico-negro-compacto">
          <img src="/img/catalogo/acrilico-negro-compacto.webp" alt="Comprar podium compacto de acrilico negro para presentaciones en espacios pequenos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Acrilico Compacto</span>
          <h3>Podium Acrilico Negro Compacto</h3>
          <p>Podium compacto en acrilico negro con acabado premium, optimizado para presentaciones en espacios reducidos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/acrilico-negro-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/podium-madera-negro-compacto">
          <img src="/img/catalogo/podium-madera-negro-compacto.webp" alt="Comprar podium compacto de madera negra para oficinas corporativas y salas de capacitacion" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Madera Compacto</span>
          <h3>Podium Madera Negro Compacto</h3>
          <p>Version compacta del podium de madera negra, perfecto para oficinas corporativas y salas de capacitacion.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/podium-madera-negro-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
      <div class="product-card">
        <a href="/catalogo/madera-caoba-acrilico-compacto">
          <img src="/img/catalogo/madera-caoba-acrilico-compacto.webp" alt="Comprar podium compacto combinado de madera caoba con acrilico para eventos exclusivos" width="400" height="220" loading="lazy" />
        </a>
        <div class="card-content">
          <span class="card-tag">Combinado Compacto</span>
          <h3>Podium Madera y Acrilico Compacto</h3>
          <p>Combinacion premium de madera caoba y acrilico en formato compacto para espacios pequenos y eventos selectos.</p>
          <div class="card-actions">
            <a href="/contacto" class="btn-primary">Cotizar</a>
            <a href="/catalogo/madera-caoba-acrilico-compacto" class="btn-call">Ver Detalles</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="benefits-section">
    <div class="section-header">
      <h2>Beneficios de Comprar tu Podium en PODIUMEX</h2>
      <p>Cada compra incluye ventajas exclusivas para garantizar tu satisfaccion.</p>
    </div>
    <div class="cards-grid">
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Logistica</span>
          <h3>Envio Nacional</h3>
          <p>Envio seguro y asegurado a cualquier ciudad de Mexico. Entrega express en 24 horas para CDMX y area metropolitana con seguimiento en tiempo real de tu pedido.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Calidad</span>
          <h3>Garantia de Fabrica</h3>
          <p>Todos nuestros podiums incluyen garantia de fabrica que cubre defectos de manufactura y materiales. Respaldo total en la calidad de tu inversion.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Branding</span>
          <h3>Personalizacion con Logo</h3>
          <p>Personaliza tu podium con grabado laser o rotulacion vinilica de tu logo corporativo. Opciones de iluminacion LED y acabados especiales disponibles.</p>
        </div>
      </div>
      <div class="service-card">
        <div class="card-content">
          <span class="card-tag">Pagos</span>
          <h3>Financiamiento Flexible</h3>
          <p>Opciones de pago a meses sin intereses con tarjeta de credito. Tambien aceptamos transferencia bancaria, deposito y pagos corporativos con factura.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-content">
      <h2>Compra tu Podium Profesional</h2>
      <p>Recibe una cotizacion personalizada con las mejores condiciones del mercado. Envio a todo Mexico.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20comprar%20un%20podium%20profesional" target="_blank" rel="noopener noreferrer" class="btn-whatsapp">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Comprar por WhatsApp
        </a>
        <a href="/contacto" class="btn-call">Contactar</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-catalog, .benefits-section {
    padding: 4rem 0 0;
  }
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 1rem;
    padding: 0 2rem;
  }
  .section-header h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 0.75rem;
  }
  .section-header p {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.7;
  }
  .card-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }
  .card-actions .btn-primary,
  .card-actions .btn-call {
    padding: 0.625rem 1.25rem;
    font-size: 0.85rem;
  }
</style>
