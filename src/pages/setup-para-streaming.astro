---
import Layout from '../layouts/Layout.astro';

const title = "Setup para Streaming - Eventos Hibridos | PODIUMEX Mexico";
const description = "Configuracion profesional de podiums para streaming y eventos hibridos. Iluminacion, posicionamiento de camaras y compatibilidad con plataformas digitales.";
---

<Layout title={title} description={description} canonical="/setup-para-streaming">

  <div class="breadcrumbs" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <a href="/servicios" class="breadcrumb-link">Servicios</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <span class="breadcrumb-current">Setup para Streaming</span>
    </div>
  </div>

  <section class="hero" style="padding-top:2rem;">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Setup para <span class="highlight">Streaming</span></h1>
        <p>Preparamos tu podium para transmisiones en vivo y eventos hibridos con la mejor configuracion tecnica profesional.</p>
        <div class="hero-stats">
          <div class="stat-item"><span class="stat-number">4K</span><span class="stat-label">Compatible</span></div>
          <div class="stat-item"><span class="stat-number">100%</span><span class="stat-label">Profesional</span></div>
          <div class="stat-item"><span class="stat-number">HD</span><span class="stat-label">Audio</span></div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20necesito%20setup%20para%20streaming" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar Setup
          </a>
          <a href="tel:+525564328954" class="btn-call">Llamar Ahora</a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Eventos Hibridos con Calidad Profesional</h2>
        <p>Los eventos hibridos son la nueva normalidad. En PODIUMEX configuramos tu podium para que se vea impecable tanto en persona como en transmision digital. Nuestro servicio de setup para streaming incluye posicionamiento optimizado para camaras, iluminacion adecuada y asesoria tecnica.</p>
        <p>Trabajamos con las principales plataformas de streaming y videoconferencia para asegurar compatibilidad total. Tu audiencia remota vera una presentacion tan profesional como la presencial.</p>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-content">
      <div class="trust-item"><div class="trust-text"><h3>Zoom / Teams / Meet</h3><p>Compatible</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Iluminacion</h3><p>Optimizada</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Audio Profesional</h3><p>Configurado</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Asesoria Tecnica</h3><p>Incluida</p></div></div>
    </div>
  </div>

  <section class="service-single-content">
    <div class="service-intro-section">
      <h2>Que Incluye el Setup para Streaming</h2>
      <p>Nuestro servicio abarca todos los aspectos tecnicos para que tu podium luzca perfecto en transmisiones digitales. Desde el angulo de camara hasta la iluminacion, cada detalle esta pensado para proyectar profesionalismo.</p>
    </div>

    <div class="service-two-col">
      <div class="service-col">
        <h3>Configuracion Visual</h3>
        <ul class="service-list">
          <li>Posicionamiento optimizado para angulos de camara</li>
          <li>Recomendaciones de iluminacion frontal y lateral</li>
          <li>Eliminacion de reflejos en podiums de acrilico</li>
          <li>Fondos y escenografia complementaria</li>
          <li>Pruebas de imagen en vivo antes del evento</li>
        </ul>
      </div>
      <div class="service-col">
        <h3>Configuracion de Audio</h3>
        <ul class="service-list">
          <li>Posicionamiento de microfono de cuello de ganso</li>
          <li>Configuracion de audio para streaming</li>
          <li>Pruebas de sonido con la plataforma elegida</li>
          <li>Eliminacion de eco y ruido ambiental</li>
          <li>Backup de audio por seguridad</li>
        </ul>
      </div>
    </div>

    <div class="info-cards-grid">
      <div class="info-card"><h4>Conferencias Virtuales</h4><p>Setup optimizado para Zoom, Teams, Meet y Webex con la mejor calidad de imagen y audio.</p></div>
      <div class="info-card"><h4>Eventos Hibridos</h4><p>Configuracion que funciona tanto para la audiencia presencial como para los asistentes remotos.</p></div>
      <div class="info-card"><h4>Grabacion Profesional</h4><p>Preparacion del escenario para grabaciones de video profesional y contenido de alta calidad.</p></div>
    </div>

    <div class="service-banner">
      <h3>Compatible con Todas las Plataformas</h3>
      <p>Nuestro setup esta probado y optimizado para funcionar con Zoom, Microsoft Teams, Google Meet, Webex, YouTube Live, Facebook Live y cualquier plataforma de streaming. Tambien ofrecemos asesoria para produccion con OBS y software profesional de transmision.</p>
    </div>

    <!-- WhatsApp Form -->
    <div style="margin-top:3rem;">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Cotiza tu Setup</h2>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
        <form id="whatsappForm" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Nombre *</label><input type="text" name="nombre" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu nombre"></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Plataforma</label><input type="text" name="plataforma" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Zoom, Teams, etc."></div>
          <div style="grid-column:1/-1;"><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Detalles del Evento</label><textarea name="mensaje" rows="3" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;resize:vertical;" placeholder="Describe tu evento..."></textarea></div>
          <div style="grid-column:1/-1;"><button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 2rem;background:#25D366;color:white;border:none;border-radius:var(--radius-md);font-weight:600;font-size:0.95rem;cursor:pointer;font-family:inherit;">Enviar por WhatsApp</button></div>
        </form>
      </div>
    </div>

    <div class="service-faq-section">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Preguntas sobre Streaming</h2>
      <div class="service-faq-item"><div class="service-faq-question"><span>Que equipo necesito para el streaming?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Nosotros nos encargamos de la configuracion del podium. Tu necesitas la camara, computadora y conexion a internet. Te asesoramos sobre los requisitos minimos.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Funcionan los podiums de acrilico en camara?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Si, los podiums de acrilico lucen excelentes en camara. Configuramos la iluminacion para minimizar reflejos y resaltar el grabado laser de tu logo.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Incluye soporte durante la transmision?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Si, ofrecemos soporte tecnico durante la transmision por WhatsApp o con tecnico en sitio (con cargo adicional).</p></div></div></div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2>Prepara tu Evento Hibrido</h2>
      <p>Configura tu podium para una transmision impecable. Cotizacion sin compromiso.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20necesito%20setup%20de%20streaming%20para%20mi%20evento" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
        <a href="/servicios" class="btn-call">Ver Servicios</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.service-faq-question').forEach(btn => { btn.addEventListener('click', () => { btn.parentElement?.classList.toggle('active'); }); });
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const d = (n: string) => (f.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value || '';
      let t = `Hola, necesito setup para streaming:\n\n*Nombre:* ${d('nombre')}`;
      if (d('plataforma')) t += `\n*Plataforma:* ${d('plataforma')}`;
      if (d('mensaje')) t += `\n*Detalles:* ${d('mensaje')}`;
      window.open(`https://wa.me/525564328954?text=${encodeURIComponent(t)}`, '_blank');
    });
  </script>

</Layout>
