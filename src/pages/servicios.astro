---
import Layout from '../layouts/Layout.astro';
import { webPageSchema, breadcrumb } from '../data/schema';
import SectionHeader from '../components/SectionHeader.astro';
import QuickLinks from '../components/QuickLinks.astro';
import CtaFinal from '../components/CtaFinal.astro';
import HelpSection from '../components/HelpSection.astro';

const title = "Servicios para Eventos con Podiums en México | PODIUMEX";
const description = "Servicios integrales para eventos: entrega express, personalización con grabado láser, streaming y soporte técnico. Renta y venta de podiums en México.";

// ─── Datos: Servicios (8) ────────────────────────────────────────────
const servicios = [
  {
    href: '/entrega-e-instalacion',
    title: 'Entrega e Instalación',
    desc: 'Entrega express y montaje profesional en tu sede, con rastreo en tiempo real.',
    tag: 'Express',
    image: '/img/img-general/montaje-atril-evento-profesional.webp',
    imageAlt: 'Montaje profesional de podium en evento corporativo',
  },
  {
    href: '/personalizacion-total',
    title: 'Personalización Premium',
    desc: 'Grabado láser de logo, escudos institucionales y vinilado de alta precisión.',
    tag: 'Premium',
    image: '/img/img-general/acabado-acrilico-calidad-premium.webp',
    imageAlt: 'Detalle de acabado premium en personalización de podium',
  },
  {
    href: '/setup-para-streaming',
    title: 'Setup para Streaming',
    desc: 'Configuración para transmisiones en vivo: iluminación y posicionamiento para cámara.',
    tag: 'Digital',
    image: '/img/img-general/setup-streaming-podium-chroma.webp',
    imageAlt: 'Setup de streaming profesional con podium y pantalla verde',
  },
  {
    href: '/soporte-tecnico',
    title: 'Soporte Técnico 24/7',
    desc: 'Asistencia técnica antes y durante tu evento, con respuesta en menos de 2 horas.',
    tag: '24/7',
    image: '/img/img-general/soporte-tecnico-atril-conferencia.webp',
    imageAlt: 'Técnico dando soporte a podium durante conferencia',
  },
  {
    href: '/financiamiento',
    title: 'Financiamiento Flexible',
    desc: 'Meses sin intereses y esquemas de financiamiento corporativo para tu compra.',
    tag: 'Finanzas',
    image: '/img/img-general/presentacion-ejecutiva-podium-corporativo.webp',
    imageAlt: 'Presentación ejecutiva con podium corporativo',
  },
  {
    href: '/mantenimiento',
    title: 'Mantenimiento Profesional',
    desc: 'Limpieza, pulido y restauración que prolongan la vida útil de tu podium.',
    tag: 'Cuidado',
    image: '/img/img-general/control-calidad-atril-acrilico.webp',
    imageAlt: 'Control de calidad y mantenimiento de podium de acrílico',
  },
  {
    href: '/sustentabilidad',
    title: 'Sustentabilidad Certificada',
    desc: 'Maderas FSC, acrílicos reciclables y procesos de fabricación responsables.',
    tag: 'ESG',
    image: '/img/img-general/fabricacion-podium-material-acrilico.webp',
    imageAlt: 'Fabricación sustentable de podium con materiales certificados',
  },
  {
    href: '/asesoria-de-eventos',
    title: 'Asesoría de Eventos',
    desc: 'Consultoría sin costo para elegir el podium y el setup ideal para tu evento.',
    tag: 'Gratis',
    image: '/img/img-general/expositor-podium-acrilico-congreso.webp',
    imageAlt: 'Expositor en podium de acrílico durante congreso profesional',
  },
];

const schema = webPageSchema({
  name: 'Servicios Profesionales para Eventos',
  description,
  path: '/servicios',
  type: 'WebPage',
});

const breadcrumbSchema = breadcrumb([
  { name: 'Inicio', path: '/' },
  { name: 'Servicios' },
]);
---

<Layout title={title} description={description} canonical="/servicios" schema={schema} breadcrumbSchema={breadcrumbSchema}>

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Ruta de navegación" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <span class="breadcrumb-current" aria-current="page">Servicios</span>
    </div>
  </nav>

  <!-- ══════════════════════════════════════════════════
       HERO (homologado al index)
  ══════════════════════════════════════════════════ -->
  <section class="ix-hero" aria-labelledby="serv-hero-title">
    <div class="ix-hero-inner">

      <!-- Columna izquierda: headline -->
      <div class="ix-hero-copy">
        <div class="ix-eyebrow">
          <span class="ix-eyebrow-dot" aria-hidden="true"></span>
          8 servicios · Cobertura nacional · Desde 2020
        </div>
        <h1 id="serv-hero-title">
          <span class="ix-highlight">Servicios Profesionales</span><br>
          para Eventos Impecables
        </h1>
        <p class="ix-hero-desc">
          Más allá del podium: un ecosistema de servicios que cubre cada detalle de tu
          evento, desde la entrega y la personalización hasta el streaming y el soporte técnico.
        </p>
      </div>

      <!-- Columna derecha: contenido SEO + marketing -->
      <div class="ix-hero-editorial">
        <p class="ix-editorial-p">
          Coordinamos <strong>entrega express, grabado láser de logo, setup para transmisiones
          en vivo y soporte técnico</strong> durante el evento — todo con un solo proveedor y
          desde una sola llamada, en CDMX y toda la República Mexicana.
        </p>
        <p class="ix-editorial-p">
          Cada servicio está respaldado por más de <strong>1,500 eventos exitosos</strong>,
          un equipo capacitado y garantía escrita. Sumamos financiamiento a meses sin intereses,
          mantenimiento profesional y asesoría sin costo.
        </p>
      </div>

    </div>
  </section>

  <!-- Accesos rápidos -->
  <QuickLinks items={[
    { icon: 'catalogo', label: 'Catálogo Completo', sub: '8 modelos disponibles', href: '/catalogo' },
    { icon: 'renta', label: 'Renta de Podiums', sub: 'Por día, semana o evento', href: '/renta-de-podiums' },
    { icon: 'venta', label: 'Venta de Podiums', sub: 'Compra con garantía escrita', href: '/venta-de-podiums' },
    { icon: 'faq', label: 'Preguntas Frecuentes', sub: 'Resuelve tus dudas', href: '/preguntas-frecuentes' },
    { icon: 'whatsapp', label: 'Cotización Gratuita', sub: 'Respuesta en menos de 2 horas', href: 'https://wa.me/525516567973?text=Hola%2C%20quiero%20una%20cotizaci%C3%B3n%20de%20servicios', accent: true, external: true },
  ]} />

  <!-- ══════════════════════════════════════════════════
       SERVICIOS (grid homologado al index)
  ══════════════════════════════════════════════════ -->
  <section class="ix-section ix-section-alt" aria-labelledby="servicios-title">
    <div class="ix-container">
      <SectionHeader
        tag="Servicios"
        title="Solución Integral para tu Evento"
        description="Ocho servicios especializados que garantizan que cada detalle de tu presentación sea impecable, de principio a fin."
        id="servicios-title"
        p1="<strong>Entrega e instalación express, personalización con grabado láser, setup para streaming</strong> y soporte técnico durante el evento — coordinado por un solo equipo."
        p2="Además: <strong>financiamiento a meses sin intereses, mantenimiento profesional</strong>, certificación ESG y asesoría de eventos sin costo para que cada decisión sea la correcta."
      />

      <div class="ix-services-grid">
        {servicios.map((s) => (
          <a href={s.href} class="ix-service-card">
            <div class="ix-service-img">
              <img src={s.image} alt={s.imageAlt} width="400" height="180" loading="lazy" />
              <span class="ix-service-tag">{s.tag}</span>
            </div>
            <div class="ix-service-body">
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
              <span class="ix-service-cta">Ver servicio →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="ix-section-footer">
        <a href="/catalogo" class="btn-primary">Ver Catálogo de Podiums</a>
        <a href="/contacto" class="btn-call">Hablar con un Asesor</a>
      </div>
    </div>
  </section>

  <CtaFinal
    title="¿Listo para que tu Evento sea Impecable?"
    text="Cuéntanos qué necesitas por WhatsApp. Un asesor especializado te responde con servicios, precios y tiempos de entrega ese mismo día."
    waMessage="Hola, me interesan sus servicios profesionales para un evento"
  />

  <HelpSection />

</Layout>
