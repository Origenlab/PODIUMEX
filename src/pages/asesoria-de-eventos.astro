---
import Layout from '../layouts/Layout.astro';

const title = "Asesoria de Eventos - Seleccion de Podiums | PODIUMEX Mexico";
const description = "Asesoria profesional para seleccion de podiums en eventos. Te ayudamos a elegir el podium ideal segun tipo de evento, espacio, audiencia y presupuesto.";
---

<Layout title={title} description={description} canonical="/asesoria-de-eventos">

  <div class="breadcrumbs" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <a href="/servicios" class="breadcrumb-link">Servicios</a>
      <span class="breadcrumb-arrow">&rsaquo;</span>
      <span class="breadcrumb-current">Asesoria de Eventos</span>
    </div>
  </div>

  <section class="hero" style="padding-top:2rem;">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Asesoria de <span class="highlight">Eventos</span></h1>
        <p>Nuestros expertos te ayudan a elegir el podium perfecto para tu evento. Asesoria personalizada sin compromiso.</p>
        <div class="hero-stats">
          <div class="stat-item"><span class="stat-number">1,500+</span><span class="stat-label">Eventos Asesorados</span></div>
          <div class="stat-item"><span class="stat-number">100%</span><span class="stat-label">Gratis</span></div>
          <div class="stat-item"><span class="stat-number">Pro</span><span class="stat-label">Expertos</span></div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20necesito%20asesoria%20para%20mi%20evento" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Pedir Asesoria
          </a>
          <a href="tel:+525564328954" class="btn-call">Llamar Ahora</a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Asesoria Experta para Eventos Exitosos</h2>
        <p>Elegir el podium correcto puede marcar la diferencia entre un evento bueno y uno extraordinario. Nuestro equipo de asesores especializados tiene la experiencia de mas de 1,500 eventos exitosos para guiarte en la seleccion perfecta.</p>
        <p>Consideramos todos los factores: tipo de evento, tamano del espacio, audiencia esperada, imagen de marca, necesidades tecnicas y presupuesto. Nuestra asesoria es completamente gratuita y sin compromiso, porque sabemos que un cliente bien informado es un cliente satisfecho.</p>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-content">
      <div class="trust-item"><div class="trust-text"><h3>Asesoria Gratis</h3><p>Sin compromiso</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Expertos</h3><p>+5 anos de experiencia</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Personalizada</h3><p>Para cada evento</p></div></div>
      <div class="trust-item"><div class="trust-text"><h3>Respuesta Rapida</h3><p>Menos de 1 hora</p></div></div>
    </div>
  </div>

  <section class="service-single-content">
    <div class="service-intro-section">
      <h2>En que Te Asesoramos</h2>
      <p>Nuestra asesoria abarca todos los aspectos relacionados con la seleccion y uso de podiums en tu evento. Te ayudamos a tomar la mejor decision en cada aspecto.</p>
    </div>

    <div class="service-two-col">
      <div class="service-col">
        <h3>Seleccion de Producto</h3>
        <ul class="service-list">
          <li>Recomendacion del modelo ideal para tu evento</li>
          <li>Comparativa de materiales (acrilico vs madera)</li>
          <li>Seleccion de tamano (estandar vs compacto)</li>
          <li>Opciones de personalizacion y grabado</li>
          <li>Asesoria sobre venta vs renta</li>
        </ul>
      </div>
      <div class="service-col">
        <h3>Logistica del Evento</h3>
        <ul class="service-list">
          <li>Posicionamiento optimo en el escenario</li>
          <li>Coordinacion con equipo de audio y video</li>
          <li>Recomendaciones de iluminacion</li>
          <li>Planificacion de tiempos de montaje</li>
          <li>Configuracion para streaming si aplica</li>
        </ul>
      </div>
    </div>

    <div class="service-intro-section">
      <h2>Tipos de Eventos que Asesoramos</h2>
    </div>

    <div class="event-types" style="margin-bottom:3rem;">
      <div class="event-type-card"><h4>Conferencias Corporativas</h4><p>Presentaciones ejecutivas, juntas de consejo, reportes trimestrales y eventos de empresa.</p></div>
      <div class="event-type-card"><h4>Conferencias de Prensa</h4><p>Ruedas de prensa, lanzamientos de productos y comunicados oficiales.</p></div>
      <div class="event-type-card"><h4>Eventos de Gobierno</h4><p>Ceremonias oficiales, informes de gobierno, eventos protocolarios y actos publicos.</p></div>
      <div class="event-type-card"><h4>Congresos y Seminarios</h4><p>Congresos academicos, seminarios profesionales, conferencias magistrales y paneles de discusion.</p></div>
      <div class="event-type-card"><h4>Ceremonias y Galas</h4><p>Graduaciones, premiaciones, inauguraciones y eventos de gala.</p></div>
      <div class="event-type-card"><h4>Eventos Hibridos</h4><p>Eventos con audiencia presencial y virtual, webinars y transmisiones en vivo.</p></div>
    </div>

    <div class="service-banner">
      <h3>Asesoria 100% Gratuita</h3>
      <p>Nuestra asesoria es completamente gratuita y sin compromiso de compra. Creemos que un cliente bien informado toma mejores decisiones. Contactanos por WhatsApp, telefono o email y recibiras atencion personalizada de uno de nuestros expertos en menos de 1 hora.</p>
    </div>

    <div style="margin-top:3rem;">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Solicita Asesoria</h2>
      <div style="background:var(--white);border:1px solid var(--border);border-radius:var(--radius-lg);padding:2rem;">
        <form id="whatsappForm" style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Nombre *</label><input type="text" name="nombre" required style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Tu nombre"></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Tipo de Evento</label><input type="text" name="evento" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Conferencia, congreso, etc."></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Fecha Aproximada</label><input type="text" name="fecha" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Fecha del evento"></div>
          <div><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Ubicacion</label><input type="text" name="ubicacion" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;" placeholder="Ciudad o venue"></div>
          <div style="grid-column:1/-1;"><label style="display:block;font-size:0.85rem;font-weight:500;color:var(--primary);margin-bottom:0.375rem;">Detalles del Evento</label><textarea name="mensaje" rows="3" style="width:100%;padding:0.75rem 1rem;border:1px solid var(--border);border-radius:var(--radius-md);font-size:0.9rem;font-family:inherit;resize:vertical;" placeholder="Cuentanos sobre tu evento, audiencia y necesidades..."></textarea></div>
          <div style="grid-column:1/-1;"><button type="submit" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 2rem;background:#25D366;color:white;border:none;border-radius:var(--radius-md);font-weight:600;font-size:0.95rem;cursor:pointer;font-family:inherit;">Enviar por WhatsApp</button></div>
        </form>
      </div>
    </div>

    <div class="service-faq-section">
      <h2 style="font-size:1.5rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem;">Preguntas sobre Asesoria</h2>
      <div class="service-faq-item"><div class="service-faq-question"><span>La asesoria tiene algun costo?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>No, nuestra asesoria es 100% gratuita y sin compromiso de compra. Queremos que tomes la mejor decision para tu evento.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Pueden visitar mi venue para asesorarme?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Si, en CDMX podemos realizar visitas al venue para evaluar el espacio y darte recomendaciones mas precisas. Contactanos para agendar una visita.</p></div></div></div>
      <div class="service-faq-item"><div class="service-faq-question"><span>Cuanto tiempo tarda recibir la asesoria?</span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg></div><div class="service-faq-answer"><div class="service-faq-answer-content"><p>Respondemos consultas por WhatsApp en menos de 1 hora. Para asesorias mas detalladas, podemos agendar una llamada o videollamada en el mismo dia.</p></div></div></div>
    </div>
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2>Haz que tu Evento sea Perfecto</h2>
      <p>Recibe asesoria experta gratuita para elegir el podium ideal. Sin compromiso.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20necesito%20asesoria%20para%20elegir%20un%20podium%20para%20mi%20evento" class="btn-whatsapp" target="_blank" rel="noopener noreferrer">Pedir Asesoria por WhatsApp</a>
        <a href="/servicios" class="btn-call">Ver Servicios</a>
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.service-faq-question').forEach(btn => { btn.addEventListener('click', () => { btn.parentElement?.classList.toggle('active'); }); });
    document.getElementById('whatsappForm')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const d = (n: string) => (f.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value || '';
      let t = `Hola, necesito asesoria para mi evento:\n\n*Nombre:* ${d('nombre')}`;
      if (d('evento')) t += `\n*Tipo de evento:* ${d('evento')}`;
      if (d('fecha')) t += `\n*Fecha:* ${d('fecha')}`;
      if (d('ubicacion')) t += `\n*Ubicacion:* ${d('ubicacion')}`;
      if (d('mensaje')) t += `\n*Detalles:* ${d('mensaje')}`;
      window.open(`https://wa.me/525564328954?text=${encodeURIComponent(t)}`, '_blank');
    });
  </script>

</Layout>
