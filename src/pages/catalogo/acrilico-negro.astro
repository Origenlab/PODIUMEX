---
import Layout from '../../layouts/Layout.astro';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Podium de Acrilico Negro",
  "image": "https://podiumex.com/img/catalogo/acrilico-negro.webp",
  "description": "Podium de acrilico negro premium con acabado mate. Elegante y moderno para presentaciones ejecutivas, galas y eventos de alto nivel.",
  "sku": "PDX-ACR-NEG-001",
  "brand": {
    "@type": "Brand",
    "name": "PODIUMEX"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "76"
  }
});
---

<Layout title="Podium de Acrilico Negro - Renta y Venta de Podiums | PODIUMEX" description="Podium de acrilico negro premium con acabado mate. Elegante y moderno para presentaciones ejecutivas, galas y eventos de alto nivel." canonical="/catalogo/acrilico-negro" schema={schema}>

  <nav class="breadcrumbs" aria-label="Navegacion">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow">></span>
      <a href="/catalogo" class="breadcrumb-link">Catalogo</a>
      <span class="breadcrumb-arrow">></span>
      <span class="breadcrumb-current">Podium de Acrilico Negro</span>
    </div>
  </nav>

  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Podium de <span class="highlight">Acrilico Negro</span></h1>
        <p>Elegancia y sofisticacion en acabado mate premium. Perfecto para presentaciones ejecutivas, galas y eventos donde cada detalle importa.</p>
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">120cm</span>
            <span class="stat-label">Altura</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">9kg</span>
            <span class="stat-label">Peso</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">6mm</span>
            <span class="stat-label">Acrilico</span>
          </div>
        </div>
        <div class="hero-cta">
          <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20el%20Podium%20de%20Acrilico%20Negro%20(PDX-ACR-NEG-001)" class="btn-whatsapp" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
          <a href="/contacto" class="btn-call">Solicitar Cotizacion</a>
        </div>
      </div>
      <div class="hero-intro">
        <h2>Podium de acrilico negro mate para eventos ejecutivos en Mexico</h2>
        <p>El podium de acrilico negro es la opcion ideal para quienes buscan proyectar autoridad y sofisticacion. Su acabado mate elimina reflejos indeseados y crea un contraste elegante en cualquier escenario, desde salas de conferencias hasta auditorios de gran formato.</p>
        <p>Disponible en renta y venta en PODIUMEX, cada podium de acrilico negro esta fabricado con materiales de primera calidad y un proceso de acabado que garantiza una superficie uniforme y resistente al uso continuo en eventos profesionales.</p>
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="trust-content">
      <div class="trust-item">
        <div class="trust-text">
          <h3>Envio e Instalacion</h3>
          <p>En CDMX y area metropolitana</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Acabado Mate Premium</h3>
          <p>Sin reflejos, aspecto profesional</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Soporte Personalizado</h3>
          <p>Asesoria para tu evento</p>
        </div>
      </div>
      <div class="trust-item">
        <div class="trust-text">
          <h3>Disponibilidad Inmediata</h3>
          <p>Stock listo para entrega</p>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:4rem 2rem;max-width:1200px;margin:0 auto">
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:1.5rem">
      <img src="/img/catalogo/acrilico-negro.webp" alt="Podium de acrilico negro mate para eventos ejecutivos" loading="lazy" style="width:100%;border-radius:12px;aspect-ratio:4/3;object-fit:cover">
      <img src="/img/catalogo/acrilico-negro-lateral.webp" alt="Vista lateral del podium acrilico negro profesional" loading="lazy" style="width:100%;border-radius:12px;aspect-ratio:4/3;object-fit:cover">
      <img src="/img/catalogo/acrilico-negro-detalle.webp" alt="Detalle del acabado mate premium del podium acrilico negro" loading="lazy" style="width:100%;border-radius:12px;aspect-ratio:4/3;object-fit:cover">
    </div>
  </section>

  <section style="padding:0 2rem 4rem;max-width:1200px;margin:0 auto">
    <h2 style="font-size:1.75rem;font-weight:700;color:var(--primary);margin-bottom:1.5rem">Especificaciones Tecnicas</h2>
    <table style="width:100%;border-collapse:collapse;margin-bottom:2rem">
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary);width:40%">Material</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">Acrilico negro 6mm</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border);background:var(--secondary)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">Altura</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">120cm</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">Ancho</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">35cm</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border);background:var(--secondary)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">Profundidad</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">30cm</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">Peso</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">9kg</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border);background:var(--secondary)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">Color</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">Negro mate</td>
      </tr>
      <tr style="border-bottom:1px solid var(--border)">
        <td style="padding:0.75rem 1rem;font-weight:600;color:var(--primary)">SKU</td>
        <td style="padding:0.75rem 1rem;color:var(--text-medium)">PDX-ACR-NEG-001</td>
      </tr>
    </table>

    <h3 style="font-size:1.25rem;font-weight:700;color:var(--primary);margin-bottom:1rem">Caracteristicas</h3>
    <ul style="list-style:none;display:flex;flex-direction:column;gap:0.5rem;margin-bottom:2rem">
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Acabado mate premium que elimina reflejos y huellas</li>
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Superficie amplia para documentos, laptop o microfono</li>
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Base reforzada con sistema antideslizante</li>
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Ligero y facil de transportar con solo 9kg de peso</li>
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Contraste elegante que resalta al orador en el escenario</li>
      <li style="padding-left:1.25rem;position:relative;font-size:0.95rem;color:var(--text-medium);line-height:1.6">Ideal para galas, premiaciones y presentaciones ejecutivas</li>
    </ul>
  </section>

  <section class="cards-grid">
    <h2 style="grid-column:1/-1;font-size:1.75rem;font-weight:700;color:var(--primary);text-align:center;margin-bottom:1rem">Modelos Relacionados</h2>
    <a href="/catalogo/acrilico-transparente" class="product-card">
      <img src="/img/catalogo/acrilico-transparente.webp" alt="Podium de acrilico transparente" loading="lazy">
      <div class="card-content">
        <span class="card-tag">Acrilico</span>
        <h3>Podium Acrilico Transparente</h3>
        <p>Diseño moderno y minimalista con acrilico de 6mm pulido para eventos corporativos.</p>
      </div>
    </a>
    <a href="/catalogo/acrilico-negro-compacto" class="product-card">
      <img src="/img/catalogo/acrilico-negro-compacto.webp" alt="Podium acrilico negro compacto" loading="lazy">
      <div class="card-content">
        <span class="card-tag">Compacto</span>
        <h3>Acrilico Negro Compacto</h3>
        <p>Version compacta perfecta para estudios de grabacion y espacios reducidos.</p>
      </div>
    </a>
    <a href="/catalogo/podium-madera-negro" class="product-card">
      <img src="/img/catalogo/podium-madera-negro.webp" alt="Podium de madera negra" loading="lazy">
      <div class="card-content">
        <span class="card-tag">Madera</span>
        <h3>Podium Madera Negro</h3>
        <p>Clasico podium de madera negra lacada para ceremonias oficiales.</p>
      </div>
    </a>
  </section>

  <section class="cta-section">
    <div class="cta-content">
      <h2>Cotiza tu Podium de Acrilico Negro</h2>
      <p>Contactanos para obtener una cotizacion personalizada. Ofrecemos renta y venta con entrega en toda la CDMX y area metropolitana.</p>
      <div class="cta-buttons">
        <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20el%20Podium%20de%20Acrilico%20Negro%20(PDX-ACR-NEG-001)" class="btn-whatsapp" target="_blank" rel="noopener">Cotizar por WhatsApp</a>
        <a href="/contacto" class="btn-call">Solicitar Cotizacion</a>
      </div>
    </div>
  </section>

</Layout>
