---
import Layout from '../../layouts/Layout.astro';
import { productSchema, breadcrumb, faqSchema } from '../../data/schema';
import SectionHeader from '../../components/SectionHeader.astro';
import QuickLinks from '../../components/QuickLinks.astro';
import CtaFinal from '../../components/CtaFinal.astro';
import HelpSection from '../../components/HelpSection.astro';
import { homeFaqs } from '../../data/faqs';

const sku = 'PDX-ACR-TRANS-001';
const waMsg = 'Hola, me interesa el Podium de Acrílico Transparente (PDX-ACR-TRANS-001). ¿Renta o venta?';
const waHref = `https://wa.me/525516567973?text=${encodeURIComponent(waMsg)}`;

const gallery = [
  { src: '/img/catalogo/acrilico-transparente.webp', alt: 'Podium de acrílico transparente vista frontal profesional' },
  { src: '/img/catalogo/acrilico-transparente-lateral.webp', alt: 'Podium de acrílico transparente vista lateral con perfil delgado' },
  { src: '/img/catalogo/acrilico-transparente-detalle.webp', alt: 'Detalle del acabado pulido del podium de acrílico transparente' },
];

const especificaciones = [
  ['Material', 'Acrílico transparente 6 mm'],
  ['Altura', '120 cm'],
  ['Ancho', '35 cm'],
  ['Profundidad', '30 cm'],
  ['Peso', '9 kg'],
  ['Color', 'Transparente cristalino'],
  ['Garantía', '2 años (escrita)'],
  ['SKU', sku],
];

const caracteristicas = [
  'Acrílico de alta transparencia con bordes pulidos a espejo.',
  'Superficie amplia para notas, laptop o micrófono.',
  'Base estable con sistema antideslizante.',
  'Ligero (9 kg): fácil de transportar e instalar.',
  'Compatible con branding por vinilo o grabado láser.',
  'Ideal para conferencias, ruedas de prensa y eventos corporativos.',
];

const beneficios = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z"/></svg>`,
    title: 'Protagonismo del orador',
    desc: 'Su transparencia crea un escenario limpio donde la atención queda en quien habla, sin obstruir la vista del público.',
    badge: 'Diseño',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Imagen moderna',
    desc: 'Proyecta innovación y apertura: el modelo preferido por empresas líderes y lanzamientos de producto.',
    badge: 'Premium',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>`,
    title: 'Renta o venta',
    desc: 'Por evento con entrega, instalación y recolección, o compra con garantía escrita y financiamiento a meses.',
    badge: 'Flexible',
  },
];

const relacionados = [
  { href: '/catalogo/acrilico-negro', tag: 'Acrílico', title: 'Acrílico Negro', desc: 'Sofisticación de alto contraste para galas, premiaciones y eventos VIP.', image: '/img/catalogo/acrilico-negro.webp', imageAlt: 'Podium de acrílico negro mate premium' },
  { href: '/catalogo/acrilico-transparente-compacto', tag: 'Compacto', title: 'Acrílico Transparente Compacto', desc: 'La misma elegancia en formato reducido para estudios y salas de juntas.', image: '/img/catalogo/acrilico-transparente-compacto.webp', imageAlt: 'Podium de acrílico transparente compacto' },
  { href: '/catalogo/madera-caoba-acrilico', tag: 'Combinado', title: 'Madera y Acrílico', desc: 'Calidez de la madera caoba con la modernidad del frente de acrílico.', image: '/img/catalogo/madera-caoba-acrilico.webp', imageAlt: 'Podium de madera caoba con frente de acrílico' },
];

const description = 'Renta y venta del podium de acrílico transparente: diseño minimalista de 120 cm en acrílico de 6 mm pulido. Ideal para conferencias y eventos corporativos en México. Entrega en 24 h y garantía escrita.';

const schema = productSchema({
  name: 'Podium de Acrílico Transparente',
  slug: 'acrilico-transparente',
  description,
  images: gallery.map((g) => g.src),
  sku,
  material: 'Acrílico',
});

const breadcrumbSchema = breadcrumb([
  { name: 'Inicio', path: '/' },
  { name: 'Catálogo', path: '/catalogo' },
  { name: 'Acrílico Transparente' },
]);

const faqLd = faqSchema(homeFaqs);
const check = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
const checkSm = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
---

<Layout
  title="Podium de Acrílico Transparente | Renta y Venta | PODIUMEX"
  description={description}
  canonical="/catalogo/acrilico-transparente"
  ogType="product"
  ogImage="/img/catalogo/acrilico-transparente.webp"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Ruta de navegación" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <a href="/catalogo" class="breadcrumb-link">Catálogo</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <span class="breadcrumb-current" aria-current="page">Acrílico Transparente</span>
    </div>
  </nav>

  <!-- ══ FICHA DE PRODUCTO ══ -->
  <section class="ix-section ix-pdp" aria-labelledby="pdp-title">
    <div class="ix-container">
      <div class="ix-pdp-grid">

        <!-- Galería -->
        <div class="ix-pdp-gallery">
          <img id="pdpMain" class="ix-pdp-main" src={gallery[0].src} alt={gallery[0].alt} width="800" height="600" />
          <div class="ix-pdp-thumbs">
            {gallery.map((g, i) => (
              <img
                class={`ix-pdp-thumb${i === 0 ? ' is-active' : ''}`}
                src={g.src}
                alt={g.alt}
                data-full={g.src}
                width="260"
                height="195"
                loading="lazy"
              />
            ))}
          </div>
        </div>

        <!-- Info -->
        <div class="ix-pdp-info">
          <div class="ix-eyebrow">
            <span class="ix-eyebrow-dot" aria-hidden="true"></span>
            Acrílico · Más Popular
          </div>
          <h1 id="pdp-title">Podium de <span class="ix-highlight">Acrílico Transparente</span></h1>
          <p class="ix-pdp-price">Desde $8,500 MXN <small>· venta · o renta por evento</small></p>
          <p class="ix-pdp-desc">
            Diseño moderno y minimalista que aporta elegancia a cualquier conferencia o evento
            corporativo. Fabricado en acrílico de 6 mm pulido a espejo para un acabado cristalino e impecable.
          </p>

          <ul class="ix-pdp-specs">
            <li><span class="l">Altura</span><span class="v">120 cm</span></li>
            <li><span class="l">Material</span><span class="v">Acrílico 6 mm</span></li>
            <li><span class="l">Peso</span><span class="v">9 kg</span></li>
            <li><span class="l">Garantía</span><span class="v">2 años</span></li>
          </ul>

          <div class="ix-pdp-actions">
            <a href={waHref} class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
            <a href="/contacto" class="btn-call">Solicitar cotización</a>
          </div>

          <ul class="ix-pdp-trust">
            <li><Fragment set:html={checkSm} />Entrega en 24 h en CDMX</li>
            <li><Fragment set:html={checkSm} />Garantía escrita 2 años</li>
            <li><Fragment set:html={checkSm} />Personalización con tu logo</li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- Accesos rápidos -->
  <QuickLinks items={[
    { icon: 'catalogo', label: 'Ver Todo el Catálogo', sub: '8 modelos disponibles', href: '/catalogo' },
    { icon: 'renta', label: 'Renta de Podiums', sub: 'Por día, semana o evento', href: '/renta-de-podiums' },
    { icon: 'venta', label: 'Venta de Podiums', sub: 'Compra con garantía escrita', href: '/venta-de-podiums' },
    { icon: 'personalizacion', label: 'Personalización', sub: 'Grabado láser de tu logo', href: '/personalizacion-total' },
    { icon: 'whatsapp', label: 'Cotización Gratuita', sub: 'Respuesta en menos de 2 horas', href: waHref, accent: true, external: true },
  ]} />

  <!-- ══ ESPECIFICACIONES + CARACTERÍSTICAS ══ -->
  <section class="ix-section" aria-labelledby="specs-title">
    <div class="ix-container">
      <SectionHeader
        tag="Ficha Técnica"
        title="Especificaciones y Características"
        description="Todo lo que necesitas saber del podium de acrílico transparente antes de cotizar."
        id="specs-title"
        p1="Un podium fabricado en <strong>acrílico de grado óptico de 6 mm</strong>, pulido a espejo en todos sus bordes para un acabado cristalino y sin imperfecciones."
        p2="Pensado para <strong>conferencias, ruedas de prensa, lanzamientos y eventos corporativos</strong> donde la imagen moderna es parte del mensaje."
      />
      <div class="ix-pdp-grid">
        <table class="ix-spec-table">
          {especificaciones.map(([k, v]) => (<tr><th>{k}</th><td>{v}</td></tr>))}
        </table>
        <ul class="ix-feature-list">
          {caracteristicas.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
        </ul>
      </div>
    </div>
  </section>

  <!-- ══ BENEFICIOS ══ -->
  <section class="ix-section ix-section-alt" aria-labelledby="benef-title">
    <div class="ix-container">
      <SectionHeader
        tag="¿Por qué este modelo?"
        title="Pensado para que tu Evento Comunique"
        description="Tres razones por las que el acrílico transparente es el favorito de empresas e instituciones."
        id="benef-title"
        p1="El podium <strong>comunica antes de que el orador hable</strong>. El acrílico transparente proyecta una imagen moderna, limpia y profesional."
        p2="Y porque cada pieza incluye <strong>garantía escrita, entrega express y personalización</strong>, la decisión es sencilla."
      />
      <div class="ix-diff-grid" style="grid-template-columns:repeat(3,1fr);">
        {beneficios.map((b) => (
          <div class="ix-diff-card">
            <div class="ix-diff-icon" set:html={b.icon} aria-hidden="true"></div>
            <span class="ix-diff-badge">{b.badge}</span>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ MODELOS RELACIONADOS ══ -->
  <section class="ix-section" aria-labelledby="rel-title">
    <div class="ix-container">
      <SectionHeader
        tag="Catálogo"
        title="Modelos Relacionados"
        description="Otros podiums que también podrían encajar con el estilo de tu evento."
        id="rel-title"
        p1="Tenemos <strong>8 modelos en acrílico, madera y combinados</strong>, en talla estándar y compacta, para cada contexto de presentación."
        p2="¿No sabes cuál elegir? Te asesoramos <strong>sin costo</strong> según tu tipo de evento, aforo y presupuesto."
      />
      <div class="ix-services-grid" style="grid-template-columns:repeat(3,1fr);">
        {relacionados.map((r) => (
          <a href={r.href} class="ix-service-card">
            <div class="ix-service-img">
              <img src={r.image} alt={r.imageAlt} width="400" height="180" loading="lazy" />
              <span class="ix-service-tag">{r.tag}</span>
            </div>
            <div class="ix-service-body">
              <h3>{r.title}</h3>
              <p>{r.desc}</p>
              <span class="ix-service-cta">Ver modelo →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="ix-section-footer">
        <a href="/catalogo" class="btn-primary">Ver Catálogo Completo</a>
      </div>
    </div>
  </section>

  <CtaFinal
    eyebrow="Cotización gratuita · Respuesta en menos de 2 horas"
    title="Cotiza tu Podium de Acrílico Transparente"
    text="Dinos si lo necesitas en renta o venta, la fecha y la ciudad de tu evento. Te respondemos con precio, disponibilidad y tiempos ese mismo día."
    waText="Cotizar este Modelo"
    waMessage={waMsg}
  />

  <HelpSection />

  <script type="application/ld+json" set:html={faqLd} />

  <script is:inline>
    // Galería: clic en miniatura cambia la imagen principal
    (function () {
      const main = document.getElementById('pdpMain');
      if (!main) return;
      document.querySelectorAll('.ix-pdp-thumb').forEach((th) => {
        th.addEventListener('click', () => {
          main.src = th.getAttribute('data-full');
          main.alt = th.getAttribute('alt');
          document.querySelectorAll('.ix-pdp-thumb').forEach((t) => t.classList.remove('is-active'));
          th.classList.add('is-active');
        });
      });
    })();
  </script>

</Layout>
