---
import Layout from '../../layouts/Layout.astro';
import { productSchema, breadcrumb, faqSchema } from '../../data/schema';
import SectionHeader from '../../components/SectionHeader.astro';
import QuickLinks from '../../components/QuickLinks.astro';
import CtaFinal from '../../components/CtaFinal.astro';
import HelpSection from '../../components/HelpSection.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import { homeFaqs } from '../../data/faqs';

const sku = 'PDX-ACR-NEG-CMP-001';
const waMsg = 'Hola, me interesa el Podium de Acrílico Negro Compacto (PDX-ACR-NEG-CMP-001). ¿Renta o venta?';
const waHref = `https://wa.me/525516567973?text=${encodeURIComponent(waMsg)}`;

const gallery = [
  { src: '/img/catalogo/acrilico-negro-compacto.webp', alt: 'Podium compacto de acrílico negro mate para eventos íntimos y oficinas' },
  { src: '/img/catalogo/acrilico-negro-compacto-lateral.webp', alt: 'Vista lateral del podium compacto de acrílico negro' },
  { src: '/img/catalogo/acrilico-negro-compacto-detalle.webp', alt: 'Detalle del acabado mate del podium compacto de acrílico negro' },
];

const especificaciones = [
  ['Material', 'Acrílico negro 8 mm'],
  ['Acabado', 'Mate antirreflejante'],
  ['Tamaño', 'Compacto'],
  ['Altura', '95 cm'],
  ['Ancho', '40 cm'],
  ['Profundidad', '28 cm'],
  ['Peso', '8 kg'],
  ['Color', 'Negro mate'],
  ['Garantía', '2 años (escrita)'],
  ['SKU', sku],
];

const caracteristicas = [
  'La presencia del acrílico negro mate en formato reducido.',
  'Altura de 95 cm, ideal para espacios privados y mesas de honor.',
  'Acabado mate que elimina reflejos y huellas bajo reflectores.',
  'Acrílico de 8 mm: solidez y elegancia en una pieza compacta.',
  'Ligero (8 kg): fácil de transportar y reposicionar.',
  'Superficie suficiente para notas, tablet o micrófono.',
  'Base estable con tacos antideslizantes.',
  'Compatible con grabado láser o vinilo para tu marca.',
];

const incluyeRenta = [
  'Entrega e instalación en tu sede',
  'Nivelación y prueba en sitio',
  'Soporte técnico durante el evento',
  'Recolección al finalizar',
];
const incluyeVenta = [
  'Garantía escrita de 2 años',
  'Financiamiento a meses sin intereses',
  'Grabado láser de tu logo (opcional)',
  'Factura para empresa o gobierno',
];
const idealPara = [
  'Eventos íntimos', 'Oficinas y salas de juntas', 'Galas pequeñas',
  'Presentaciones privadas', 'Cenas ejecutivas', 'Podcasts premium', 'Streaming de alto nivel',
];

const beneficios = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`,
    title: 'Lujo en formato reducido',
    desc: 'La sofisticación del acrílico negro mate adaptada a oficinas, salas de juntas y eventos donde el espacio es limitado.',
    badge: 'Compacto',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`,
    title: 'Acabado mate sin reflejos',
    desc: 'El mate elimina destellos y huellas, ideal para fotografía, video y transmisiones en espacios cerrados con luz intensa.',
    badge: 'Premium',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
    title: 'Renta o venta',
    desc: 'Por evento con entrega, instalación y recolección, o compra con garantía escrita y financiamiento a meses.',
    badge: 'Flexible',
  },
];

const relacionados = [
  { href: '/catalogo/acrilico-negro', tag: 'Estándar', title: 'Acrílico Negro', desc: 'El modelo de tamaño completo (120 cm) para galas, premiaciones y eventos VIP.', image: '/img/catalogo/acrilico-negro.webp', imageAlt: 'Podium de acrílico negro mate premium' },
  { href: '/catalogo/acrilico-transparente-compacto', tag: 'Compacto', title: 'Acrílico Transparente Compacto', desc: 'La elegancia minimalista del acrílico transparente en formato reducido.', image: '/img/catalogo/acrilico-transparente-compacto.webp', imageAlt: 'Podium compacto de acrílico transparente' },
  { href: '/catalogo/podium-madera-negro-compacto', tag: 'Compacto', title: 'Madera Negro Compacto', desc: 'La solidez de la madera lacada en formato reducido para salas y juntas.', image: '/img/catalogo/podium-madera-negro-compacto.webp', imageAlt: 'Podium compacto de madera negra' },
  { href: '/catalogo/madera-caoba-acrilico-compacto', tag: 'Compacto', title: 'Madera y Acrílico Compacto', desc: 'El diseño híbrido premium en formato reducido para espacios exclusivos.', image: '/img/catalogo/madera-caoba-acrilico-compacto.webp', imageAlt: 'Podium compacto de madera caoba con acrílico' },
];

const description = 'Renta y venta del podium de acrílico negro compacto (95 cm, 8 mm mate): la sofisticación del acrílico negro en formato reducido para eventos íntimos, oficinas y galas pequeñas en México. Entrega en 24 h y garantía escrita.';

const schema = productSchema({
  name: 'Podium de Acrílico Negro Compacto',
  slug: 'acrilico-negro-compacto',
  description,
  images: gallery.map((g) => g.src),
  sku,
  material: 'Acrílico',
});

const breadcrumbSchema = breadcrumb([
  { name: 'Inicio', path: '/' },
  { name: 'Catálogo', path: '/catalogo' },
  { name: 'Acrílico Negro Compacto' },
]);

const faqLd = faqSchema(homeFaqs);
const check = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
---

<Layout
  title="Podium Acrílico Negro Compacto | Renta y Venta | PODIUMEX"
  description={description}
  canonical="/catalogo/acrilico-negro-compacto"
  ogType="product"
  ogImage="/img/catalogo/acrilico-negro-compacto.webp"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Ruta de navegación" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <a href="/catalogo" class="breadcrumb-link">Catálogo</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <span class="breadcrumb-current" aria-current="page">Acrílico Negro Compacto</span>
    </div>
  </nav>

  <!-- ══ HERO (idéntico al index) ══ -->
  <section class="ix-hero" aria-labelledby="pdp-title">
    <div class="ix-hero-inner">
      <div class="ix-hero-copy">
        <div class="ix-eyebrow">
          <span class="ix-eyebrow-dot" aria-hidden="true"></span>
          Acrílico · Compacto
        </div>
        <h1 id="pdp-title">
          Podium <span class="ix-highlight">Acrílico Negro Compacto</span>
        </h1>
        <p class="ix-hero-desc">
          La presencia del acrílico negro mate en formato reducido. Perfecto para eventos íntimos,
          ceremonias de menor escala y presentaciones en espacios privados.
        </p>
      </div>
      <div class="ix-hero-editorial">
        <p class="ix-editorial-p">
          Con <strong>95 cm de altura y acabado mate antirreflejante</strong>, conserva el lujo y la
          formalidad del acrílico negro estándar en una huella mucho más manejable.
        </p>
        <p class="ix-editorial-p">
          Disponible en <strong>renta o venta desde $6,900 MXN</strong>, con entrega en 24 h en CDMX,
          garantía escrita de 2 años y personalización con grabado láser de tu logo.
        </p>
      </div>
    </div>
  </section>

  <!-- Accesos rápidos -->
  <QuickLinks items={[
    { icon: 'catalogo', label: 'Ver Todo el Catálogo', sub: '8 modelos disponibles', href: '/catalogo' },
    { icon: 'renta', label: 'Renta de Podiums', sub: 'Por día, semana o evento', href: '/renta-de-podiums' },
    { icon: 'venta', label: 'Venta de Podiums', sub: 'Compra con garantía escrita', href: '/venta-de-podiums' },
    { icon: 'personalizacion', label: 'Personalización', sub: 'Grabado láser de tu logo', href: '/personalizacion-total' },
    { icon: 'whatsapp', label: 'Cotización Gratuita', sub: 'Respuesta en menos de 2 horas', href: waHref, accent: true, external: true },
  ]} />

  <!-- ══ DETALLE DEL PRODUCTO (contenido + sidebar de interlinking) ══ -->
  <section class="ix-section" aria-label="Detalle del producto">
    <div class="ix-container">
      <div class="ix-with-sidebar">

        <!-- Columna principal -->
        <div class="ix-main">
          <!-- Galería (grid 3 por fila) -->
          <div class="ix-pdp-gallery3">
            {gallery.map((g) => (
              <img src={g.src} alt={g.alt} width="400" height="300" loading="lazy" />
            ))}
          </div>

          <h2>Especificaciones técnicas</h2>
          <p>
            La versión <strong>compacta del acrílico negro mate</strong>: 95 cm de altura y acrílico de
            8 mm con acabado antirreflejante. Pensado para eventos íntimos, oficinas y galas pequeñas
            donde el lujo debe adaptarse al espacio.
          </p>

          <div class="ix-specgrid">
            {especificaciones.map(([k, v]) => (
              <div class="ix-spec"><span class="l">{k}</span><span class="v">{v}</span></div>
            ))}
          </div>

          <div class="ix-callout">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p><strong>Acabado mate:</strong> a diferencia del acrílico brillante, la superficie mate no genera destellos bajo reflectores ni muestra huellas, por lo que luce impecable en fotografía y video incluso en espacios cerrados.</p>
          </div>

          <h2>¿Qué incluye?</h2>
          <div class="ix-twocol">
            <div class="ix-infocard">
              <h3>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                En renta (por evento)
              </h3>
              <ul class="ix-feature-list">
                {incluyeRenta.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
              </ul>
            </div>
            <div class="ix-infocard">
              <h3>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                En venta
              </h3>
              <ul class="ix-feature-list">
                {incluyeVenta.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
              </ul>
            </div>
          </div>

          <h2>Características</h2>
          <ul class="ix-feature-list ix-feature-list--2col">
            {caracteristicas.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
          </ul>

          <h3>Ideal para</h3>
          <div class="ix-tags">
            {idealPara.map((t) => (<span class="ix-tag">{t}</span>))}
          </div>
        </div>

        <!-- Sidebar de interlinking -->
        <ProductSidebar
          currentSlug="acrilico-negro-compacto"
          modelName="Podium Acrílico Negro Compacto"
          price="Desde $6,900 MXN"
          waHref={waHref}
        />

      </div>
    </div>
  </section>

  <!-- ══ BENEFICIOS ══ -->
  <section class="ix-section ix-section-alt" aria-labelledby="benef-title">
    <div class="ix-container">
      <SectionHeader
        tag="¿Por qué este modelo?"
        title="Sofisticación a Escala Íntima"
        description="Tres razones por las que el acrílico negro compacto brilla en espacios privados."
        id="benef-title"
        p1="En una oficina o un evento íntimo, un podium de 120 cm sobra. Este modelo <strong>conserva la elegancia mate</strong> en una huella discreta."
        p2="Y porque cada pieza incluye <strong>garantía escrita, entrega express y personalización</strong>, la decisión es sencilla."
      />
      <div class="ix-diff-grid" style="grid-template-columns:repeat(3,1fr);">
        {beneficios.map((b) => (
          <div class="ix-diff-card">
            <div class="ix-diff-icon" set:html={b.icon} aria-hidden="true"></div>
            <span class="ix-diff-badge">{b.badge}</span>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ MODELOS RELACIONADOS ══ -->
  <section class="ix-section" aria-labelledby="rel-title">
    <div class="ix-container">
      <SectionHeader
        tag="Catálogo"
        title="Modelos Relacionados"
        description="Otros podiums que también podrían encajar con el estilo de tu evento."
        id="rel-title"
        p1="Tenemos <strong>8 modelos en acrílico, madera y combinados</strong>, en talla estándar y compacta, para cada contexto de presentación."
        p2="¿No sabes cuál elegir? Te asesoramos <strong>sin costo</strong> según tu tipo de evento, aforo y presupuesto."
      />
      <div class="ix-services-grid ix-cards-tall">
        {relacionados.map((r) => (
          <a href={r.href} class="ix-service-card">
            <div class="ix-service-img">
              <img src={r.image} alt={r.imageAlt} width="400" height="180" loading="lazy" />
              <span class="ix-service-tag">{r.tag}</span>
            </div>
            <div class="ix-service-body">
              <h3>{r.title}</h3>
              <p>{r.desc}</p>
              <span class="ix-service-cta">Ver modelo →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="ix-section-footer">
        <a href="/catalogo" class="btn-primary">Ver Catálogo Completo</a>
      </div>
    </div>
  </section>

  <CtaFinal
    eyebrow="Cotización gratuita · Respuesta en menos de 2 horas"
    title="Cotiza tu Podium Acrílico Negro Compacto"
    text="Dinos si lo necesitas en renta o venta, la fecha y la ciudad de tu evento. Te respondemos con precio, disponibilidad y tiempos ese mismo día."
    waText="Cotizar este Modelo"
    waMessage={waMsg}
  />

  <HelpSection />

  <script type="application/ld+json" set:html={faqLd} />

</Layout>
