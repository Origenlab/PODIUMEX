---
import Layout from '../../layouts/Layout.astro';
import { productSchema, breadcrumb, faqSchema } from '../../data/schema';
import SectionHeader from '../../components/SectionHeader.astro';
import QuickLinks from '../../components/QuickLinks.astro';
import CtaFinal from '../../components/CtaFinal.astro';
import HelpSection from '../../components/HelpSection.astro';
import ProductSidebar from '../../components/ProductSidebar.astro';
import { homeFaqs } from '../../data/faqs';

const sku = 'PDX-MAD-CAO-CMP-001';
const waMsg = 'Hola, me interesa el Podium de Madera y Acrílico Compacto (PDX-MAD-CAO-CMP-001). ¿Renta o venta?';
const waHref = `https://wa.me/525516567973?text=${encodeURIComponent(waMsg)}`;

const gallery = [
  { src: '/img/catalogo/madera-caoba-acrilico-compacto.webp', alt: 'Podium compacto de madera caoba con frente de acrílico para eventos exclusivos y hoteles boutique' },
  { src: '/img/catalogo/madera-caoba-acrilico-compacto-lateral.webp', alt: 'Vista lateral del podium compacto de madera caoba con acrílico' },
  { src: '/img/catalogo/madera-caoba-acrilico-compacto-detalle.webp', alt: 'Detalle de la unión de madera caoba y acrílico del podium compacto' },
];

const especificaciones = [
  ['Material', 'Madera caoba + acrílico'],
  ['Acabado', 'Caoba lacada + frente acrílico'],
  ['Tamaño', 'Compacto'],
  ['Altura', '95 cm'],
  ['Ancho', '45 cm'],
  ['Profundidad', '35 cm'],
  ['Peso', '13 kg'],
  ['Color', 'Caoba / acrílico'],
  ['Garantía', '3 años (escrita)'],
  ['SKU', sku],
];

const caracteristicas = [
  'Cuerpo de madera caoba lacada con fascia de acrílico, en formato reducido.',
  'El diseño híbrido más exclusivo del catálogo, adaptado a espacios íntimos.',
  'Frente de acrílico ideal para grabado láser o vinilo de tu marca.',
  'Altura de 95 cm, perfecta para showrooms, salas ejecutivas y mesas de honor.',
  'Acabado premium que distingue cualquier evento de marca.',
  'Estructura sólida y estable pese a su tamaño compacto.',
  'Repisa interior oculta para cables y control de presentación.',
  'Pieza de imagen: comunica distinción incluso en espacios pequeños.',
];

const incluyeRenta = [
  'Entrega e instalación en tu sede',
  'Nivelación y prueba en sitio',
  'Soporte técnico durante el evento',
  'Recolección al finalizar',
];
const incluyeVenta = [
  'Garantía escrita de 3 años',
  'Financiamiento a meses sin intereses',
  'Grabado láser de tu logo (opcional)',
  'Factura para empresa o gobierno',
];
const idealPara = [
  'Hoteles boutique', 'Showrooms y galerías', 'Eventos exclusivos', 'Lanzamientos íntimos',
  'Bodas de autor', 'Salas ejecutivas premium', 'Presentaciones de marca',
];

const beneficios = [
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    title: 'Diseño híbrido a escala íntima',
    desc: 'La calidez de la madera caoba y la modernidad del acrílico, ahora en un formato que encaja en showrooms, hoteles boutique y salas exclusivas.',
    badge: 'Híbrido',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: 'Tu marca, en primer plano',
    desc: 'La fascia de acrílico recibe tu logo con grabado láser o vinilo, con un acabado cristalino que eleva la imagen de tu evento.',
    badge: 'Personalizable',
  },
  {
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>`,
    title: 'Renta o venta',
    desc: 'Por evento con entrega, instalación y recolección, o compra con garantía escrita de 3 años y financiamiento a meses.',
    badge: 'Flexible',
  },
];

const relacionados = [
  { href: '/catalogo/madera-caoba-acrilico', tag: 'Estándar', title: 'Madera y Acrílico', desc: 'El modelo de tamaño completo (120 cm), el más exclusivo del catálogo.', image: '/img/catalogo/madera-caoba-acrilico.webp', imageAlt: 'Podium de madera caoba con frente de acrílico' },
  { href: '/catalogo/podium-madera-negro-compacto', tag: 'Compacto', title: 'Madera Negro Compacto', desc: 'La solidez de la madera lacada en formato reducido para salas y juntas.', image: '/img/catalogo/podium-madera-negro-compacto.webp', imageAlt: 'Podium compacto de madera negra' },
  { href: '/catalogo/acrilico-negro-compacto', tag: 'Compacto', title: 'Acrílico Negro Compacto', desc: 'La sofisticación del acrílico negro mate en formato reducido.', image: '/img/catalogo/acrilico-negro-compacto.webp', imageAlt: 'Podium compacto de acrílico negro' },
  { href: '/catalogo/acrilico-transparente-compacto', tag: 'Compacto', title: 'Acrílico Transparente Compacto', desc: 'La elegancia minimalista del acrílico transparente en formato reducido.', image: '/img/catalogo/acrilico-transparente-compacto.webp', imageAlt: 'Podium compacto de acrílico transparente' },
];

const description = 'Renta y venta del podium compacto de madera caoba con frente de acrílico (95 cm): el diseño híbrido más exclusivo del catálogo, en formato reducido para hoteles boutique, showrooms y eventos de marca en México. Garantía de 3 años y entrega en 24 h.';

const schema = productSchema({
  name: 'Podium de Madera Caoba con Acrílico Compacto',
  slug: 'madera-caoba-acrilico-compacto',
  description,
  images: gallery.map((g) => g.src),
  sku,
  material: 'Madera y acrílico',
});

const breadcrumbSchema = breadcrumb([
  { name: 'Inicio', path: '/' },
  { name: 'Catálogo', path: '/catalogo' },
  { name: 'Madera y Acrílico Compacto' },
]);

const faqLd = faqSchema(homeFaqs);
const check = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
---

<Layout
  title="Podium Madera y Acrílico Compacto | Renta y Venta | PODIUMEX"
  description={description}
  canonical="/catalogo/madera-caoba-acrilico-compacto"
  ogType="product"
  ogImage="/img/catalogo/madera-caoba-acrilico-compacto.webp"
  schema={schema}
  breadcrumbSchema={breadcrumbSchema}
>

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Ruta de navegación" style="margin-top:0;">
    <div class="breadcrumbs-wrapper">
      <a href="/" class="breadcrumb-link">Inicio</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <a href="/catalogo" class="breadcrumb-link">Catálogo</a>
      <span class="breadcrumb-arrow" aria-hidden="true">&rsaquo;</span>
      <span class="breadcrumb-current" aria-current="page">Madera y Acrílico Compacto</span>
    </div>
  </nav>

  <!-- ══ HERO (idéntico al index) ══ -->
  <section class="ix-hero" aria-labelledby="pdp-title">
    <div class="ix-hero-inner">
      <div class="ix-hero-copy">
        <div class="ix-eyebrow">
          <span class="ix-eyebrow-dot" aria-hidden="true"></span>
          Combinado · Compacto
        </div>
        <h1 id="pdp-title">
          Podium <span class="ix-highlight">Madera y Acrílico Compacto</span>
        </h1>
        <p class="ix-hero-desc">
          El diseño híbrido más exclusivo del catálogo, en formato reducido. Cuerpo de madera caoba
          con fascia de acrílico para espacios íntimos donde la imagen lo es todo.
        </p>
      </div>
      <div class="ix-hero-editorial">
        <p class="ix-editorial-p">
          Reúne la <strong>calidez de la madera caoba y la transparencia del acrílico</strong> en una
          pieza compacta de 95 cm: distinción y exclusividad sin necesitar un escenario completo.
        </p>
        <p class="ix-editorial-p">
          Disponible en <strong>renta o venta desde $8,400 MXN</strong>, con entrega en 24 h en CDMX,
          garantía escrita de 3 años y tu logo grabado en la fascia de acrílico.
        </p>
      </div>
    </div>
  </section>

  <!-- Accesos rápidos -->
  <QuickLinks items={[
    { icon: 'catalogo', label: 'Ver Todo el Catálogo', sub: '8 modelos disponibles', href: '/catalogo' },
    { icon: 'renta', label: 'Renta de Podiums', sub: 'Por día, semana o evento', href: '/renta-de-podiums' },
    { icon: 'venta', label: 'Venta de Podiums', sub: 'Compra con garantía escrita', href: '/venta-de-podiums' },
    { icon: 'personalizacion', label: 'Personalización', sub: 'Grabado láser en el acrílico', href: '/personalizacion-total' },
    { icon: 'whatsapp', label: 'Cotización Gratuita', sub: 'Respuesta en menos de 2 horas', href: waHref, accent: true, external: true },
  ]} />

  <!-- ══ DETALLE DEL PRODUCTO (contenido + sidebar de interlinking) ══ -->
  <section class="ix-section" aria-label="Detalle del producto">
    <div class="ix-container">
      <div class="ix-with-sidebar">

        <!-- Columna principal -->
        <div class="ix-main">
          <!-- Galería (grid 3 por fila) -->
          <div class="ix-pdp-gallery3">
            {gallery.map((g) => (
              <img src={g.src} alt={g.alt} width="400" height="300" loading="lazy" />
            ))}
          </div>

          <h2>Especificaciones técnicas</h2>
          <p>
            La versión <strong>compacta del modelo híbrido madera caoba + acrílico</strong>: 95 cm de
            altura, cuerpo de caoba lacada y fascia de acrílico al frente. Concebido para hoteles
            boutique, showrooms y eventos de marca donde el detalle premium debe caber en el espacio.
          </p>

          <div class="ix-specgrid">
            {especificaciones.map(([k, v]) => (
              <div class="ix-spec"><span class="l">{k}</span><span class="v">{v}</span></div>
            ))}
          </div>

          <div class="ix-callout">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p><strong>Personalización de alto nivel:</strong> la fascia de acrílico recibe tu logo con grabado láser o vinilo, mientras la madera caoba aporta el marco cálido. Un modelo de imagen pensado para marcas que cuidan cada detalle, incluso en espacios reducidos.</p>
          </div>

          <h2>¿Qué incluye?</h2>
          <div class="ix-twocol">
            <div class="ix-infocard">
              <h3>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                En renta (por evento)
              </h3>
              <ul class="ix-feature-list">
                {incluyeRenta.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
              </ul>
            </div>
            <div class="ix-infocard">
              <h3>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
                En venta
              </h3>
              <ul class="ix-feature-list">
                {incluyeVenta.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
              </ul>
            </div>
          </div>

          <h2>Características</h2>
          <ul class="ix-feature-list ix-feature-list--2col">
            {caracteristicas.map((c) => (<li><Fragment set:html={check} />{c}</li>))}
          </ul>

          <h3>Ideal para</h3>
          <div class="ix-tags">
            {idealPara.map((t) => (<span class="ix-tag">{t}</span>))}
          </div>
        </div>

        <!-- Sidebar de interlinking -->
        <ProductSidebar
          currentSlug="madera-caoba-acrilico-compacto"
          modelName="Podium Madera y Acrílico Compacto"
          price="Desde $8,400 MXN"
          waHref={waHref}
        />

      </div>
    </div>
  </section>

  <!-- ══ BENEFICIOS ══ -->
  <section class="ix-section ix-section-alt" aria-labelledby="benef-title">
    <div class="ix-container">
      <SectionHeader
        tag="¿Por qué este modelo?"
        title="Exclusividad que no Necesita Espacio"
        description="Tres razones por las que el híbrido compacto es la elección premium para eventos íntimos."
        id="benef-title"
        p1="Cuando la imagen debe ser <strong>impecable y única</strong> pero el espacio es limitado, este modelo aporta calidez, modernidad y un lugar de honor para tu marca."
        p2="Y porque cada pieza incluye <strong>garantía escrita de 3 años, entrega express y personalización</strong>, la decisión es sencilla."
      />
      <div class="ix-diff-grid" style="grid-template-columns:repeat(3,1fr);">
        {beneficios.map((b) => (
          <div class="ix-diff-card">
            <div class="ix-diff-icon" set:html={b.icon} aria-hidden="true"></div>
            <span class="ix-diff-badge">{b.badge}</span>
            <h3>{b.title}</h3>
            <p>{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ MODELOS RELACIONADOS ══ -->
  <section class="ix-section" aria-labelledby="rel-title">
    <div class="ix-container">
      <SectionHeader
        tag="Catálogo"
        title="Modelos Relacionados"
        description="Otros podiums que también podrían encajar con el estilo de tu evento."
        id="rel-title"
        p1="Tenemos <strong>8 modelos en acrílico, madera y combinados</strong>, en talla estándar y compacta, para cada contexto de presentación."
        p2="¿No sabes cuál elegir? Te asesoramos <strong>sin costo</strong> según tu tipo de evento, aforo y presupuesto."
      />
      <div class="ix-services-grid ix-cards-tall">
        {relacionados.map((r) => (
          <a href={r.href} class="ix-service-card">
            <div class="ix-service-img">
              <img src={r.image} alt={r.imageAlt} width="400" height="180" loading="lazy" />
              <span class="ix-service-tag">{r.tag}</span>
            </div>
            <div class="ix-service-body">
              <h3>{r.title}</h3>
              <p>{r.desc}</p>
              <span class="ix-service-cta">Ver modelo →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="ix-section-footer">
        <a href="/catalogo" class="btn-primary">Ver Catálogo Completo</a>
      </div>
    </div>
  </section>

  <CtaFinal
    eyebrow="Cotización gratuita · Respuesta en menos de 2 horas"
    title="Cotiza tu Podium Madera y Acrílico Compacto"
    text="Dinos si lo necesitas en renta o venta, la fecha y la ciudad de tu evento. Te respondemos con precio, disponibilidad y tiempos ese mismo día."
    waText="Cotizar este Modelo"
    waMessage={waMsg}
  />

  <HelpSection />

  <script type="application/ld+json" set:html={faqLd} />

</Layout>
