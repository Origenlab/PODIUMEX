---
// HelpSection.astro — módulo FAQ acordeón + formulario a WhatsApp.
// Reutilizable y homologado. Emite FAQPage schema (rich results).
import SectionHeader from './SectionHeader.astro';
import { homeFaqs } from '../data/faqs';
import { faqSchema } from '../data/schema';

interface Props {
  tag?: string;
  title?: string;
  description?: string;
  p1?: string;
  p2?: string;
}

const {
  tag = '¿Hablamos?',
  title = 'Resuelve tus Dudas y Cotiza en un Minuto',
  description = 'Las respuestas a lo que más nos preguntan, y un formulario directo a WhatsApp para recibir tu cotización sin compromiso.',
  p1 = 'Antes de decidir es normal tener preguntas sobre <strong>tiempos de entrega, personalización, garantía o la diferencia entre venta y renta</strong>. Aquí están las más frecuentes.',
  p2 = '¿Prefieres que te contactemos? Llena el formulario y <strong>te respondemos por WhatsApp en menos de 2 horas</strong>, con una cotización detallada y sin compromiso.',
} = Astro.props;

const faqLd = faqSchema(homeFaqs);
---

<section class="ix-section ix-section-alt ix-help" aria-labelledby="help-title">
  <div class="ix-container">
    <SectionHeader tag={tag} title={title} description={description} id="help-title" p1={p1} p2={p2} />

    <div class="ix-help-grid">
      <!-- Columna 1: Preguntas frecuentes -->
      <div class="ix-help-faq">
        <h3 class="ix-help-colhead">Preguntas Frecuentes</h3>
        {homeFaqs.map((faq) => (
          <div class="faq-item">
            <button type="button" class="faq-question">
              <span>{faq.q}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-answer">
              <div class="faq-answer-content"><p>{faq.a}</p></div>
            </div>
          </div>
        ))}
        <a href="/preguntas-frecuentes" class="ix-help-alllink">Ver todas las preguntas frecuentes →</a>
      </div>

      <!-- Columna 2: Formulario a WhatsApp -->
      <div class="ix-help-form">
        <h3 class="ix-help-colhead">Cotiza por WhatsApp</h3>
        <p class="ix-help-form-sub">Completa estos datos y te respondemos en menos de 2 horas. Sin compromiso.</p>
        <form id="ixQuoteForm" class="ix-form" novalidate>
          <div>
            <label for="ixq-nombre">Nombre *</label>
            <input id="ixq-nombre" type="text" name="nombre" required placeholder="Tu nombre completo" autocomplete="name">
          </div>
          <div class="ix-form-row">
            <div>
              <label for="ixq-tel">Teléfono *</label>
              <input id="ixq-tel" type="tel" name="telefono" required placeholder="55 1234 5678" autocomplete="tel">
            </div>
            <div>
              <label for="ixq-empresa">Empresa</label>
              <input id="ixq-empresa" type="text" name="empresa" placeholder="Opcional" autocomplete="organization">
            </div>
          </div>
          <div class="ix-form-row">
            <div>
              <label for="ixq-servicio">¿Qué necesitas? *</label>
              <select id="ixq-servicio" name="servicio" required>
                <option value="Renta de podium">Renta de podium</option>
                <option value="Compra de podium">Compra de podium</option>
                <option value="Personalización / grabado">Personalización / grabado</option>
                <option value="Asesoría para mi evento">Asesoría para mi evento</option>
              </select>
            </div>
            <div>
              <label for="ixq-modelo">Modelo de interés</label>
              <select id="ixq-modelo" name="modelo">
                <option value="">Sin preferencia</option>
                <option value="Acrílico Transparente">Acrílico Transparente</option>
                <option value="Acrílico Negro">Acrílico Negro</option>
                <option value="Madera Negro">Madera Negro</option>
                <option value="Madera y Acrílico">Madera y Acrílico</option>
              </select>
            </div>
          </div>
          <div>
            <label for="ixq-msg">Cuéntanos de tu evento</label>
            <textarea id="ixq-msg" name="mensaje" rows="3" placeholder="Fecha, ciudad, tipo de evento, número de asistentes..."></textarea>
          </div>
          <button type="submit" class="ix-form-submit btn-whatsapp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar por WhatsApp
          </button>
          <p class="ix-form-note">Se abrirá WhatsApp con tu información lista para enviar. No compartimos tus datos.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={faqLd} />

<script is:inline>
  // El acordeón FAQ lo gestiona js/app.js (initializeFAQ) globalmente.
  // Formulario → WhatsApp
  document.getElementById('ixQuoteForm') && document.getElementById('ixQuoteForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const f = e.target;
    const v = (n) => { const el = f.querySelector('[name="' + n + '"]'); return el ? el.value.trim() : ''; };
    const nombre = v('nombre'), telefono = v('telefono');
    if (!nombre || !telefono) { alert('Por favor escribe tu nombre y teléfono.'); return; }
    let t = 'Hola PODIUMEX, quiero una cotización:\n\n';
    t += '*Nombre:* ' + nombre + '\n';
    t += '*Teléfono:* ' + telefono + '\n';
    if (v('empresa')) t += '*Empresa:* ' + v('empresa') + '\n';
    t += '*Necesito:* ' + v('servicio') + '\n';
    if (v('modelo')) t += '*Modelo:* ' + v('modelo') + '\n';
    if (v('mensaje')) t += '*Detalle:* ' + v('mensaje') + '\n';
    window.open('https://wa.me/525516567973?text=' + encodeURIComponent(t), '_blank', 'noopener');
  });
</script>
