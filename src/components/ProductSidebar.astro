---
// ProductSidebar.astro — sidebar de interlinking para fichas de producto.
import { getCollection } from 'astro:content';

interface Props {
  currentSlug: string;
  modelName: string;
  price: string;
  waHref: string;
}
const { currentSlug, modelName, price, waHref } = Astro.props;

const models = [
  { slug: 'acrilico-transparente', name: 'Acrílico Transparente' },
  { slug: 'acrilico-negro', name: 'Acrílico Negro' },
  { slug: 'podium-madera-negro', name: 'Madera Negro' },
  { slug: 'madera-caoba-acrilico', name: 'Madera y Acrílico' },
  { slug: 'acrilico-transparente-compacto', name: 'Acrílico Transparente Compacto' },
  { slug: 'acrilico-negro-compacto', name: 'Acrílico Negro Compacto' },
  { slug: 'podium-madera-negro-compacto', name: 'Madera Negro Compacto' },
  { slug: 'madera-caoba-acrilico-compacto', name: 'Madera y Acrílico Compacto' },
];
const otrosModelos = models.filter((m) => m.slug !== currentSlug).slice(0, 6);

const servicios = [
  { href: '/renta-de-podiums', label: 'Renta de podiums' },
  { href: '/venta-de-podiums', label: 'Venta de podiums' },
  { href: '/personalizacion-total', label: 'Personalización con grabado láser' },
  { href: '/entrega-e-instalacion', label: 'Entrega e instalación express' },
  { href: '/servicios', label: 'Todos los servicios' },
];

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<aside class="ix-sidebar" aria-label="Enlaces de interés">

  <!-- Cotización -->
  <div class="ix-widget ix-widget--cta">
    <h4>¿Te interesa este modelo?</h4>
    <p class="ix-widget-price">{price}</p>
    <p>Cotiza el {modelName} en renta o venta. Respuesta en menos de 2 horas, sin compromiso.</p>
    <a href={waHref} class="btn-whatsapp" target="_blank" rel="noopener noreferrer">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Cotizar por WhatsApp
    </a>
    <a href="/contacto" class="ix-widget-link2">Solicitar cotización →</a>
  </div>

  <!-- Otros modelos -->
  <div class="ix-widget">
    <h4>Otros modelos del catálogo</h4>
    <ul class="ix-widget-list">
      {otrosModelos.map((m) => (<li><a href={`/catalogo/${m.slug}`}>{m.name}</a></li>))}
    </ul>
    <a href="/catalogo" class="ix-widget-more">Ver catálogo completo →</a>
  </div>

  <!-- Servicios -->
  <div class="ix-widget">
    <h4>Servicios relacionados</h4>
    <ul class="ix-widget-list">
      {servicios.map((s) => (<li><a href={s.href}>{s.label}</a></li>))}
    </ul>
  </div>

  <!-- Blog -->
  <div class="ix-widget">
    <h4>Guías que te ayudan a decidir</h4>
    <ul class="ix-widget-list">
      {posts.map((p) => (<li><a href={`/blog/${p.id}`}>{p.data.title}</a></li>))}
    </ul>
    <a href="/blog" class="ix-widget-more">Ver todas las guías →</a>
  </div>

  <!-- Atención -->
  <div class="ix-widget">
    <h4>¿Tienes dudas?</h4>
    <ul class="ix-widget-list">
      <li><a href="/preguntas-frecuentes">Preguntas frecuentes</a></li>
      <li><a href="/contacto">Contacto y cobertura</a></li>
      <li><a href="tel:+525516567973">Llámanos: 55 1656 7973</a></li>
    </ul>
  </div>

</aside>
