            WhatsApp Directo
          </a>
        </div>
      </div>

      <!-- Columna 2: Catálogo -->
      <div class="ft-col">
        <h4>Catálogo</h4>
        <ul>
          <li><a href="/venta-de-podiums">Venta de Podiums</a></li>
          <li><a href="/renta-de-podiums">Renta de Podiums</a></li>
          <li><a href="/catalogo/acrilico-transparente">Acrílico Transparente</a></li>
          <li><a href="/catalogo/acrilico-negro">Acrílico Negro</a></li>
          <li><a href="/catalogo/podium-madera-negro">Madera Negro</a></li>
          <li><a href="/catalogo/madera-caoba-acrilico">Madera y Acrílico</a></li>
          <li><a href="/catalogo" class="ft-ver-todo">Ver catálogo completo →</a></li>
        </ul>
      </div>

      <!-- Columna 3: Servicios -->
      <div class="ft-col">
        <h4>Servicios</h4>
        <ul>
          <li><a href="/entrega-e-instalacion">Entrega e Instalación</a></li>
          <li><a href="/personalizacion-total">Personalización Premium</a></li>
          <li><a href="/setup-para-streaming">Setup para Streaming</a></li>
          <li><a href="/soporte-tecnico">Soporte Técnico 24/7</a></li>
          <li><a href="/financiamiento">Financiamiento Flexible</a></li>
          <li><a href="/mantenimiento">Mantenimiento</a></li>
          <li><a href="/asesoria-de-eventos">Asesoría de Eventos</a></li>
          <li><a href="/servicios" class="ft-ver-todo">Todos los servicios →</a></li>
        </ul>
      </div>

      <!-- Columna 4: Empresa -->
      <div class="ft-col">
        <h4>Empresa</h4>
        <ul>
          <li><a href="/nosotros">Quiénes Somos</a></li>
          <li><a href="/testimonios">Testimonios</a></li>
          <li><a href="/preguntas-frecuentes">Preguntas Frecuentes</a></li>
          <li><a href="/blog">Blog y Guías</a></li>
          <li><a href="/contacto">Solicitar Cotización</a></li>
        </ul>

        <h4 style="margin-top: 1.75rem;">Legal</h4>
        <ul>
          <li><a href="/contacto">Aviso de Privacidad</a></li>
          <li><a href="/contacto">Mapa del Sitio</a></li>
        </ul>
      </div>

      <!-- Columna 5: Ubicación -->
      <div class="ft-col ft-col--location">
        <h4>Ubicación</h4>
        <div class="ft-location">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <address>
            Av. Tamaulipas 150-1301B<br>
            Col. Condesa, Cuauhtémoc<br>
            06140 Ciudad de México
          </address>
        </div>
        <a href="https://maps.google.com/?q=Av.+Tamaulipas+150,+Condesa,+Ciudad+de+México"
           class="ft-maps-link"
           target="_blank"
           rel="noopener noreferrer">
          Ver en Google Maps →
        </a>

        <div class="ft-horario">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <div>
            <span>Lun–Vie 9:00–18:00</span>
            <span>Sáb 10:00–14:00</span>
            <span class="ft-horario-note">Emergencias: WhatsApp 24/7</span>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Barra inferior -->
  <div class="ft-bottom">
    <div class="ft-bottom-inner">
      <p>&copy; 2025 PODIUMEX — Todos los derechos reservados. <span class="ft-seo">Venta y renta de podiums profesionales en México.</span></p>
      <div class="ft-bottom-badges">
        <span>Envíos a toda la República</span>
        <span>Garantía de Calidad</span>
        <span>Atención Personalizada</span>
      </div>
    </div>
  </div>
</footer>

<style>
footer {
  background: var(--primary);
  color: var(--white);
}

/* ── Grid principal ─────────────────────────────── */
.ft-main {
  max-width: 1400px;
  margin: 0 auto;
  padding: 4rem 2rem 2rem;
}
.ft-grid {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1fr 1.2fr;
  gap: 3rem;
}

/* ── Columna de marca ───────────────────────────── */
.ft-logo {
  display: inline-block;
  font-size: 1.75rem;
  font-weight: 800;
  color: var(--white);
  letter-spacing: -0.03em;
  text-decoration: none;
  margin-bottom: 1rem;
}
.ft-tagline {
  font-size: 0.84rem;
  color: rgba(255,255,255,0.55);
  line-height: 1.7;
  margin-bottom: 1.25rem;
}
.ft-badges {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}
.ft-badge {
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--accent);
  background: rgba(184,134,11,0.12);
  border: 1px solid rgba(184,134,11,0.25);
  padding: 0.25rem 0.625rem;
  border-radius: 4px;
}
.ft-contact {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.ft-contact-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.84rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s;
}
.ft-contact-item:hover { color: var(--white); }
.ft-contact-item svg { color: var(--accent); flex-shrink: 0; }
.ft-wa { color: #25D366 !important; }
.ft-wa svg { color: #25D366 !important; }
.ft-wa:hover { color: #4ade80 !important; }

/* ── Columnas de links ──────────────────────────── */
.ft-col h4 {
  font-size: 0.78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.4);
  margin-bottom: 1rem;
}
.ft-col ul {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.ft-col ul a {
  font-size: 0.855rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s;
}
.ft-col ul a:hover { color: var(--white); }
.ft-ver-todo {
  color: var(--accent) !important;
  font-weight: 600;
  margin-top: 0.25rem;
}

/* ── Ubicación ──────────────────────────────────── */
.ft-location {
  display: flex;
  gap: 0.625rem;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}
.ft-location svg { color: var(--accent); flex-shrink: 0; margin-top: 2px; }
.ft-location address {
  font-style: normal;
  font-size: 0.84rem;
  color: rgba(255,255,255,0.6);
  line-height: 1.65;
}
.ft-maps-link {
  display: inline-block;
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--accent);
  text-decoration: none;
  margin-bottom: 1.25rem;
}
.ft-maps-link:hover { color: var(--accent-light); text-decoration: underline; }
.ft-horario {
  display: flex;
  gap: 0.625rem;
  align-items: flex-start;
}
.ft-horario svg { color: rgba(255,255,255,0.3); flex-shrink: 0; margin-top: 2px; }
.ft-horario div {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
}
.ft-horario span {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
}
.ft-horario-note {
  color: var(--accent) !important;
  font-weight: 600;
}

/* ── Barra inferior ─────────────────────────────── */
.ft-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: 1.25rem 2rem;
}
.ft-bottom-inner {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 0.75rem;
}
.ft-bottom-inner p {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.35);
}
.ft-seo { opacity: 0.6; }
.ft-bottom-badges {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
}
.ft-bottom-badges span {
  font-size: 0.75rem;
  color: rgba(255,255,255,0.25);
}

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 1200px) {
  .ft-grid { grid-template-columns: 1fr 1fr 1fr; }
  .ft-brand { grid-column: span 3; }
  .ft-col--location { grid-column: span 1; }
}
@media (max-width: 768px) {
  .ft-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .ft-brand { grid-column: span 2; }
  .ft-col--location { grid-column: span 2; }
  .ft-bottom-inner { flex-direction: column; align-items: flex-start; }
}
@media (max-width: 480px) {
  .ft-grid { grid-template-columns: 1fr; }
  .ft-brand, .ft-col--location { grid-column: span 1; }
}
</style>
