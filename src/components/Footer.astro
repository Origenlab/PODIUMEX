---
// Footer.astro — pie de página profesional
---

<footer>
  <div class="ft-main">
    <div class="ft-grid">

      <!-- Columna 1: Marca + contacto -->
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="PODIUMEX – Inicio">
          PODIUMEX
        </a>
        <p class="ft-tagline">
          Especialistas en venta y renta de podiums profesionales en México. Fabricación nacional, entrega express y personalización con grabado láser.
        </p>

        <!-- Badges de confianza -->
        <div class="ft-badges">
          <span class="ft-badge">Fab. Nacional</span>
          <span class="ft-badge">Garantía 2–3 años</span>
          <span class="ft-badge">Desde 2020</span>
        </div>

        <!-- Contacto -->
        <div class="ft-contact">
          <a href="tel:+525564328954" class="ft-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.64 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +52 55 6432 8954
          </a>
          <a href="mailto:podiumexmx@gmail.com" class="ft-contact-item">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            podiumexmx@gmail.com
          </a>
          <a href="https://wa.me/525564328954?text=Hola,%20me%20interesa%20cotizar%20un%20podium" target="_blank" rel="noopener noreferrer" class="ft-contact-item ft-wa">
