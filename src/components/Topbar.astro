---
// Topbar.astro — barra superior, sin iconos
---

<div class="topbar" role="complementary" aria-label="Información de contacto">
  <div class="topbar-inner">

    <div class="topbar-left">
      <a href="tel:+525564328954" class="topbar-link">55 6432 8954</a>
      <span class="topbar-sep" aria-hidden="true">/</span>
      <a href="mailto:podiumexmx@gmail.com" class="topbar-link topbar-link--hide-sm">podiumexmx@gmail.com</a>
      <span class="topbar-sep topbar-sep--hide-sm" aria-hidden="true">/</span>
      <span class="topbar-hours">Lun–Vie 9:00–18:00 &nbsp;·&nbsp; Sáb 10:00–14:00</span>
    </div>

    <div class="topbar-right">
      <a
        href="https://wa.me/525564328954?text=Hola%2C%20quiero%20una%20cotizaci%C3%B3n%20r%C3%A1pida%20de%20un%20podium"
        class="topbar-cta"
        target="_blank"
        rel="noopener noreferrer"
      >
        Cotización rápida
      </a>
    </div>

  </div>
</div>

<style>
.topbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1100;
  background: #0a0a0a;
  height: 36px;
  display: flex;
  align-items: center;
  border-bottom: 1px solid rgba(255,255,255,.05);
}

.topbar-inner {
  max-width: 1400px;
  width: 100%;
  margin: 0 auto;
  padding: 0 2.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.topbar-left {
  display: flex;
  align-items: center;
  gap: .625rem;
}

.topbar-link {
  font-size: .72rem;
  font-weight: 500;
  color: rgba(255,255,255,.52);
  text-decoration: none;
  letter-spacing: .01em;
  white-space: nowrap;
  transition: color .15s;
}
.topbar-link:hover { color: #d4a634; }

.topbar-sep {
  font-size: .65rem;
  color: rgba(255,255,255,.2);
  user-select: none;
  letter-spacing: 0;
}

.topbar-hours {
  font-size: .7rem;
  color: rgba(255,255,255,.28);
  white-space: nowrap;
  letter-spacing: .01em;
}

.topbar-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.topbar-cta {
  font-size: .71rem;
  font-weight: 600;
  letter-spacing: .04em;
  text-transform: uppercase;
  color: #0a0a0a;
  background: #b8860b;
  padding: .22rem .875rem;
  border-radius: 50px;
  text-decoration: none;
  white-space: nowrap;
  transition: background .15s;
}
.topbar-cta:hover { background: #d4a634; }

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 900px) {
  .topbar-inner { padding: 0 1.25rem; }
  .topbar-link--hide-sm { display: none; }
  .topbar-sep--hide-sm  { display: none; }
  .topbar-hours         { display: none; }
}

@media (max-width: 480px) {
  .topbar-cta { display: none; }
}
</style>
