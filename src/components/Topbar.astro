---
// Topbar.astro — barra superior fija con datos de contacto rápido
---

<div class="topbar" role="banner" aria-label="Información de contacto">
  <div class="topbar-inner">

    <!-- Izquierda: datos de contacto -->
    <div class="topbar-left">
      <a href="tel:+525564328954" class="topbar-link" aria-label="Llamar a PODIUMEX">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.64 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.56 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 5.99 5.99l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        +52 55 6432 8954
      </a>

      <span class="topbar-sep" aria-hidden="true">·</span>

      <a href="mailto:podiumexmx@gmail.com" class="topbar-link" aria-label="Enviar email a PODIUMEX">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        podiumexmx@gmail.com
      </a>

      <span class="topbar-sep topbar-sep--hide-sm" aria-hidden="true">·</span>
      <span class="topbar-hours topbar-sep--hide-sm">Lun–Vie 9–18h &nbsp;·&nbsp; Sáb 10–14h</span>
    </div>

    <!-- Derecha: CTA rápido -->
    <div class="topbar-right">
      <a
        href="https://wa.me/525564328954?text=Hola%2C%20quiero%20una%20cotizaci%C3%B3n%20r%C3%A1pida%20de%20un%20podium"
        class="topbar-cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Cotización rápida por WhatsApp"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Cotización rápida
      </a>
    </div>

  </div>
</div>

<style>
.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 1100;
  background: #0a0a0a;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  height: 36px;
  display: flex;
  align-items: center;
}

.topbar-inner {
  max-width: 1400px;
  width: 100%;
  margin: 0 auto;
  padding: 0 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.topbar-left {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.topbar-link {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.76rem;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: color 0.15s;
  white-space: nowrap;
}
.topbar-link:hover {
  color: #d4a634;
}
.topbar-link svg {
  flex-shrink: 0;
  color: #b8860b;
}

.topbar-sep {
  color: rgba(255,255,255,0.2);
  font-size: 0.7rem;
  user-select: none;
}

.topbar-hours {
  font-size: 0.72rem;
  color: rgba(255,255,255,0.35);
  white-space: nowrap;
}

.topbar-right {
  display: flex;
  align-items: center;
}

.topbar-cta {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: #0a0a0a;
  background: #b8860b;
  padding: 0.3rem 0.875rem;
  border-radius: 50px;
  text-decoration: none;
  transition: background 0.15s;
  white-space: nowrap;
  letter-spacing: 0.01em;
}
.topbar-cta:hover {
  background: #d4a634;
}

@media (max-width: 768px) {
  .topbar-sep--hide-sm,
  .topbar-hours {
    display: none;
  }
  .topbar-inner {
    padding: 0 1rem;
  }
  .topbar-link:last-of-type {
    display: none;
  }
}
</style>
