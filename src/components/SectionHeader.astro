---
/**
 * SectionHeader.astro
 * Encabezado de sección en dos columnas:
 *   Izquierda: tag + h2 + descripción (copy de conversión)
 *   Derecha:   dos párrafos SEO/marketing
 *
 * Props:
 *   tag        — etiqueta pequeña en dorado (ej. "Catálogo")
 *   title      — H2 principal de la sección
 *   description — párrafo corto bajo el título
 *   p1         — primer párrafo columna derecha (SEO/marketing)
 *   p2         — segundo párrafo columna derecha (SEO/marketing)
 *   id         — id del h2 para aria-labelledby (opcional)
 *   titleSize  — tamaño extra del título: 'normal' | 'large' (default: 'normal')
 */

interface Props {
  tag: string;
  title: string;
  description: string;
  p1: string;
  p2: string;
  id?: string;
  titleSize?: 'normal' | 'large';
}

const {
  tag,
  title,
  description,
  p1,
  p2,
  id,
  titleSize = 'normal',
} = Astro.props;
---

<div class={`sh-wrap ${titleSize === 'large' ? 'sh-wrap--large' : ''}`}>

  <!-- Columna izquierda: título y descripción -->
  <div class="sh-left">
    <span class="ix-section-tag">{tag}</span>
    <h2 id={id}>{title}</h2>
    <p class="sh-desc">{description}</p>
    <slot />
  </div>

  <!-- Columna derecha: párrafos SEO/marketing -->
  <div class="sh-right">
    <p set:html={p1} />
    <p set:html={p2} />
  </div>

</div>

<style>
.sh-wrap {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
  margin-bottom: 3rem;
}

/* Columna izquierda */
.sh-left {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.sh-left h2 {
  font-size: clamp(1.6rem, 3vw, 2.15rem);
  font-weight: 800;
  color: var(--primary);
  line-height: 1.2;
  letter-spacing: -0.02em;
  margin: 0;
}
.sh-wrap--large .sh-left h2 {
  font-size: clamp(1.9rem, 3.5vw, 2.5rem);
}
.sh-desc {
  font-size: 0.96rem;
  color: var(--text-light);
  line-height: 1.75;
  max-width: 480px;
  margin: 0;
}

/* Columna derecha */
.sh-right {
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding-top: 0.5rem;
  border-left: 2px solid var(--border-light);
  padding-left: 3rem;
}
.sh-right p {
  font-size: 0.94rem;
  color: var(--text-medium);
  line-height: 1.85;
  margin: 0;
}
/* Negritas dentro de los párrafos SEO */
.sh-right :global(strong) {
  color: var(--primary);
  font-weight: 600;
}

/* Responsive */
@media (max-width: 900px) {
  .sh-wrap {
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  .sh-right {
    border-left: none;
    border-top: 1px solid var(--border-light);
    padding-left: 0;
    padding-top: 1.5rem;
  }
  .sh-desc {
    max-width: 100%;
  }
}
</style>
