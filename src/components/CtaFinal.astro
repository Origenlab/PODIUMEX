---
// CtaFinal.astro — banda CTA oscura reutilizable (homologada al index).
import WhatsAppButton from './WhatsAppButton.astro';

interface Secondary {
  label: string;
  href: string;
  icon?: 'catalogo' | 'phone' | 'mail';
}

interface Props {
  eyebrow?: string;
  title: string;
  text: string;
  waText?: string;
  waMessage?: string;
  secondary?: Secondary;
  trust?: string[];
}

const {
  eyebrow = 'Cotización gratuita · Respuesta en menos de 2 horas',
  title,
  text,
  waText = 'Cotizar por WhatsApp',
  waMessage = 'Hola, quiero cotizar un podium para mi evento',
  secondary = { label: 'Ver Catálogo Completo', href: '/catalogo', icon: 'catalogo' },
  trust = ['Fabricación Nacional', 'Garantía 2–3 años', 'Entrega en 24 hrs · Desde 2020'],
} = Astro.props;

const ICONS = {
  catalogo: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="7" height="7"/><rect x="15" y="3" width="7" height="7"/><rect x="15" y="14" width="7" height="7"/><rect x="2" y="14" width="7" height="7"/></svg>',
  phone: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>',
  mail: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
};
const check = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
const titleId = 'cta-' + Math.random().toString(36).slice(2, 8);
---

<section class="ix-cta-final" aria-labelledby={titleId}>
  <div class="ix-cta-final-inner">
    <div class="ix-cta-final-copy">
      <p class="ix-cta-final-eyebrow">{eyebrow}</p>
      <h2 id={titleId}>{title}</h2>
      <p>{text}</p>
    </div>
    <div class="ix-cta-final-actions">
      <WhatsAppButton text={waText} message={waMessage} />
      <a href={secondary.href} class="ix-cta-outline-btn" {...(secondary.href.startsWith('http') || secondary.href.startsWith('tel:') ? {} : {})}>
        <Fragment set:html={ICONS[secondary.icon ?? 'catalogo']} />
        {secondary.label}
      </a>
      <div class="ix-cta-trust">
        {trust.map((t) => (
          <span><Fragment set:html={check} />{t}</span>
        ))}
      </div>
    </div>
  </div>
</section>
